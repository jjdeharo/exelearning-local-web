                                                <small>
                                                    {{ t.custom_head_html_jquery_note or 'jQuery is available on all user pages.' }}
                                                    {{ t.custom_head_html_hook_label or 'To run code only in the workarea after the app is fully loaded, define' }}
                                                    <code>window.$eXeLearningCustom.init()</code>:
                                                </small>
                                                <details class="admin-code-example">
                                                    <summary>{{ t.custom_head_html_example or 'Example' }}</summary>
                                                    <pre>&lt;style&gt;
    /* Your custom CSS here */
&lt;/style&gt;

&lt;script&gt;
jQuery(function () {
    // Runs when DOM is loaded (login, workarea, error pages, etc.)
});
window.$eXeLearningCustom = {
    init: function () {
        // Runs only in the workarea, after the app has fully loaded.
        // window.eXeLearning is available here.
    }
};
&lt;/script&gt;</pre>
