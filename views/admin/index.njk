                        <div class="form-group">
                            <label>{{ t.status or 'Status' }}</label>
                            <div class="form-switch-custom">
                                <input type="checkbox" name="is_active" id="editUserActive" class="form-check-input" style="width: 40px; height: 20px;">
                                <span id="editUserStatusLabel">{{ t.active or 'Active' }}</span>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn-admin-primary btn-admin-danger me-auto" id="deleteUserBtn">
                            <span class="mi mi-sm">delete</span>
                            {{ t.delete or 'Delete' }}
                        </button>
                        <button type="button" class="btn-admin-outline" data-bs-dismiss="modal">{{ t.cancel or 'Cancel' }}</button>
                        <button type="submit" class="btn-admin-primary">
                            <span class="mi mi-sm">save</span>
                            {{ t.save or 'Save' }}
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="{{ basePath }}/libs/bootstrap/bootstrap.bundle.min.js"></script>
    <script>
        // Configuration
        const API_BASE = '{{ basePath }}/api/admin';
        const BASE_PATH = '{{ basePath }}';
        const CURRENT_ADMIN_USER_ID = Number('{{ user.id }}');
        const T = {
            confirm_delete: '{{ t.confirm_delete or "Are you sure you want to delete this user?" }}',
            confirm_delete_bulk: '{{ t.confirm_delete_bulk or "Are you sure you want to delete {count} users?" }}',
            confirm_delete_project: '{{ t.confirm_delete_project or "Are you sure you want to delete this project?" }}',
            confirm_delete_project_bulk: '{{ t.confirm_delete_project_bulk or "Are you sure you want to delete {count} projects?" }}',
            loading: '{{ t.loading or "Loading" }}',
            dashboard: '{{ t.dashboard or "Dashboard" }}',
            users: '{{ t.users or "Users" }}',
            projects: '{{ t.projects or "Projects" }}',
            extensions: '{{ t.extensions or "Extensions" }}',
            settings: '{{ t.settings or "Settings" }}',
            active: '{{ t.active or "Active" }}',
            inactive: '{{ t.inactive or "Inactive" }}',
            error_loading: '{{ t.error_loading or "Error loading data" }}',
            selected: '{{ t.selected or "selected" }}',
            deleting: '{{ t.deleting or "Deleting..." }}',
            activate: '{{ t.activate or "Activate" }}',
            deactivate: '{{ t.deactivate or "Deactivate" }}',
            archiving: '{{ t.archiving or "Archiving..." }}',
            updating: '{{ t.updating or "Updating..." }}',
            archive: '{{ t.archive or "Archive" }}',
            unlimited: '{{ t.unlimited or "Unlimited" }}',
            base: '{{ t.base or "Base" }}',
            site: '{{ t.site or "Site" }}',
            log_in_as: '{{ t.log_in_as or "Log in as" }}',
            cannot_impersonate_admin: '{{ t.cannot_impersonate_admin or "Cannot impersonate administrator users" }}',
            cannot_impersonate_self: '{{ t.cannot_impersonate_self or "Cannot impersonate your own account" }}',
            confirm_impersonate: '{{ t.confirm_impersonate or "Start impersonation as {email}?" }}',
            impersonation_failed: '{{ t.impersonation_failed or "Failed to start impersonation" }}',
            presentation: '{{ t.customization or "Customization" }}',
            maintenance: '{{ t.maintenance or "Maintenance" }}'
        };

        // State
        let currentSection = 'dashboard';
        let usersOffset = 0;
        let usersTotal = 0;
        const usersLimit = 20;
        let selectedUserIds = new Set();
        let sortBy = 'id';
        let sortOrder = 'asc';
        let projectsOffset = 0;
        let projectsTotal = 0;
        const projectsLimit = 20;
        let selectedProjectIds = new Set();
        let projectSortBy = 'id';
        let projectSortOrder = 'desc';

        // Navigation
        document.querySelectorAll('.admin-nav-link[data-section]').forEach(link => {
            link.addEventListener('click', (e) => {
                e.preventDefault();
                navigateTo(link.dataset.section);
            });
        });

        function navigateTo(section) {
            currentSection = section;

            // Update nav
            document.querySelectorAll('.admin-nav-link[data-section]').forEach(l => l.classList.remove('active'));
            document.querySelector(`[data-section="${section}"]`)?.classList.add('active');

            // Update sections
            document.querySelectorAll('.admin-section').forEach(s => s.classList.remove('active'));
            document.getElementById(section)?.classList.add('active');

            // Update title
            const titles = {
                dashboard: T.dashboard,
                users: T.users,
                projects: T.projects,
                extensions: T.extensions,
                settings: T.settings,
                presentation: T.customization,
                maintenance: T.maintenance
            };
            document.getElementById('sectionTitle').textContent = titles[section] || section;

            // Load section data
            if (section === 'dashboard') { loadStats(); loadSystemInfo(); }
            if (section === 'users') loadUsers();
            if (section === 'projects') loadProjects();

            // Close mobile sidebar
            document.getElementById('adminSidebar').classList.remove('show');
            document.getElementById('sidebarOverlay').classList.remove('show');
        }

        // Settings save
        const settingsSaveBtn = document.getElementById('settingsSaveBtn');
        const settingsSaveStatus = document.getElementById('settingsSaveStatus');

        if (settingsSaveBtn) {
            settingsSaveBtn.addEventListener('click', async () => {
                settingsSaveBtn.setAttribute('disabled', 'disabled');
                if (settingsSaveStatus) {
                    settingsSaveStatus.textContent = 'Guardando...';
                    settingsSaveStatus.classList.remove('success', 'error');
                }

                try {
                    const settings = collectAdminSettings();
                    const res = await fetch(`${API_BASE}/settings`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify({ settings }),
                    });

                    if (!res.ok) {
                        const errorData = await res.json().catch(() => ({}));
                        const detail = errorData.message || errorData.error || 'Failed to save settings';
                        throw new Error(detail);
                    }

                    if (settingsSaveStatus) {
                        settingsSaveStatus.textContent = 'Guardado';
                        settingsSaveStatus.classList.add('success');
                    }
                    updateCreateUserDefaultQuota(settings);
                } catch (err) {
                    console.error('Failed to save settings:', err);
                    if (settingsSaveStatus) {
                        settingsSaveStatus.textContent = err?.message || 'Error al guardar';
                        settingsSaveStatus.classList.add('error');
                    }
                } finally {
                    settingsSaveBtn.removeAttribute('disabled');
                }
            });
        }

        // Presentation save
        const presentationSaveBtn = document.getElementById('presentationSaveBtn');
        const presentationSaveStatus = document.getElementById('presentationSaveStatus');

        if (presentationSaveBtn) {
            presentationSaveBtn.addEventListener('click', async () => {
                presentationSaveBtn.setAttribute('disabled', 'disabled');
                if (presentationSaveStatus) {
                    presentationSaveStatus.textContent = 'Guardando...';
                    presentationSaveStatus.classList.remove('success', 'error');
                }

                try {
                    const appNameInput = document.getElementById('appNameInput');
                    const textarea = document.getElementById('customHeadHtmlInput');
                    const settings = [
                        { key: 'APP_NAME', value: appNameInput ? appNameInput.value : '', type: 'string' },
                        { key: 'CUSTOM_HEAD_HTML', value: textarea ? textarea.value : '', type: 'string' },
                    ];
                    const res = await fetch(`${API_BASE}/settings`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify({ settings }),
                    });
                    if (!res.ok) throw new Error('Failed to save');
                    const resData = await res.json();
                    // Update textarea with the sanitized value returned by the server
                    if (resData.sanitizedValues?.CUSTOM_HEAD_HTML !== undefined && textarea) {
                        textarea.value = resData.sanitizedValues.CUSTOM_HEAD_HTML;
                    }
                    if (presentationSaveStatus) {
                        presentationSaveStatus.textContent = 'Guardado';
                        presentationSaveStatus.classList.add('success');
                        setTimeout(() => {
                            presentationSaveStatus.textContent = '';
                            presentationSaveStatus.classList.remove('success');
                        }, 3000);
                    }
                } catch (err) {
                    if (presentationSaveStatus) {
                        presentationSaveStatus.textContent = 'Error';
                        presentationSaveStatus.classList.add('error');
                    }
                } finally {
                    presentationSaveBtn.removeAttribute('disabled');
                }
            });
        }

        // Maintenance save
        const maintenanceSaveBtn = document.getElementById('maintenanceSaveBtn');
        const maintenanceSaveStatus = document.getElementById('maintenanceSaveStatus');

        if (maintenanceSaveBtn) {
            maintenanceSaveBtn.addEventListener('click', async () => {
                maintenanceSaveBtn.setAttribute('disabled', 'disabled');
                if (maintenanceSaveStatus) {
                    maintenanceSaveStatus.textContent = 'Guardando...';
                    maintenanceSaveStatus.classList.remove('success', 'error');
                }

                try {
                    const toggle = document.getElementById('maintenanceModeToggle');
                    const settings = [
                        { key: 'MAINTENANCE_MODE', value: toggle && toggle.checked ? 'true' : 'false', type: 'boolean' },
                    ];
                    const res = await fetch(`${API_BASE}/settings`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'include',
                        body: JSON.stringify({ settings }),
                    });
                    if (!res.ok) throw new Error('Failed to save');

                    // Update status card UI
                    const isActive = toggle && toggle.checked;
                    const statusCard = document.getElementById('maintenanceStatusCard');
                    const statusIcon = document.getElementById('maintenanceStatusIcon');
                    const statusTitle = document.getElementById('maintenanceStatusTitle');
                    const statusDesc = document.getElementById('maintenanceStatusDesc');
                    const banner = document.getElementById('maintenanceBanner');

                    if (statusCard) {
                        statusCard.classList.toggle('maintenance-status-active', isActive);
                        statusCard.classList.toggle('maintenance-status-inactive', !isActive);
                    }
                    if (statusIcon) statusIcon.textContent = isActive ? 'engineering' : 'check_circle';
                    if (statusTitle) statusTitle.textContent = isActive ? '{{ t.maintenance_mode_active or "Maintenance mode is active" }}' : '{{ t.maintenance_mode_inactive or "Platform is online" }}';
                    if (statusDesc) statusDesc.textContent = isActive ? '{{ t.maintenance_mode_active_desc or "Non-administrator users cannot access the platform." }}' : '{{ t.maintenance_mode_inactive_desc or "All users can access the platform normally." }}';

                    // Show/hide global banner
                    if (banner) {
                        banner.classList.toggle('d-none', !isActive);
                    } else if (isActive) {
                        // Create banner dynamically if it doesn't exist yet
                        const content = document.querySelector('.admin-content');
                        if (content) {
                            const newBanner = document.createElement('div');
                            newBanner.className = 'maintenance-banner';
                            newBanner.id = 'maintenanceBanner';
                            newBanner.innerHTML = '<span class="mi mi-sm">engineering</span><strong>{{ t.maintenance_mode_active or "Maintenance mode is active" }}</strong> &mdash; {{ t.maintenance_mode_active_desc or "Non-administrator users cannot access the platform." }}';
                            content.insertBefore(newBanner, content.firstChild);
                        }
                    }

                    if (maintenanceSaveStatus) {
                        maintenanceSaveStatus.textContent = 'Guardado';
                        maintenanceSaveStatus.classList.add('success');
                        setTimeout(() => {
                            maintenanceSaveStatus.textContent = '';
                            maintenanceSaveStatus.classList.remove('success');
                        }, 3000);
                    }
                } catch (err) {
                    if (maintenanceSaveStatus) {
                        maintenanceSaveStatus.textContent = 'Error';
                        maintenanceSaveStatus.classList.add('error');
                    }
                } finally {
                    maintenanceSaveBtn.removeAttribute('disabled');
                }
            });
        }

        // =============================================
        // Favicon management
        // =============================================
        function updateFaviconPreview(hasCustomFavicon) {
            const previewArea = document.getElementById('faviconPreviewArea');
            if (!previewArea) return;
            if (hasCustomFavicon) {
                previewArea.classList.remove('d-none');
                previewArea.classList.add('d-flex');
                const img = document.getElementById('faviconPreviewImg');
                if (img) img.src = `${BASE_PATH}/customization/favicon?t=${Date.now()}`;
            } else {
                previewArea.classList.add('d-none');
                previewArea.classList.remove('d-flex');
            }
        }

        const faviconFileInput = document.getElementById('faviconFileInput');
        const faviconDeleteBtn = document.getElementById('faviconDeleteBtn');
        const faviconUploadStatus = document.getElementById('faviconUploadStatus');

        if (faviconFileInput) {
            faviconFileInput.addEventListener('change', async () => {
                const file = faviconFileInput.files?.[0];
                if (!file) return;
                if (faviconUploadStatus) {
                    faviconUploadStatus.textContent = '...';
                    faviconUploadStatus.className = 'admin-settings-status';
                }
                const formData = new FormData();
                formData.append('file', file);
                try {
                    const res = await fetch(`${API_BASE}/customization/favicon`, {
                        method: 'POST',
                        credentials: 'include',
                        body: formData,
                    });
                    if (!res.ok) {
                        const data = await res.json().catch(() => ({}));
                        throw new Error(data.message || 'Upload failed');
                    }
                    if (faviconUploadStatus) {
                        faviconUploadStatus.textContent = '✓';
                        faviconUploadStatus.classList.add('success');
                        setTimeout(() => {
                            faviconUploadStatus.textContent = '';
                            faviconUploadStatus.className = 'admin-settings-status';
                        }, 3000);
                    }
                    updateFaviconPreview(true);
                    faviconFileInput.value = '';
                } catch (err) {
                    if (faviconUploadStatus) {
                        faviconUploadStatus.textContent = err?.message || 'Error';
                        faviconUploadStatus.classList.add('error');
                    }
                }
            });
        }

        if (faviconDeleteBtn) {
            faviconDeleteBtn.addEventListener('click', async () => {
                try {
                    const res = await fetch(`${API_BASE}/customization/favicon`, {
                        method: 'DELETE',
                        credentials: 'include',
                    });
                    if (!res.ok) throw new Error('Delete failed');
                    updateFaviconPreview(false);
                } catch (err) {
                    alert(err?.message || 'Error deleting favicon');
                }
            });
        }

        // =============================================
        // Custom Assets management
        // =============================================
        function escapeHtml(str) {
            return String(str)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;');
        }

        function copyToClipboard(text) {
            navigator.clipboard.writeText(text).catch(() => {
                const el = document.createElement('textarea');
                el.value = text;
                document.body.appendChild(el);
                el.select();
                document.execCommand('copy');
                document.body.removeChild(el);
            });
        }

        async function loadCustomAssets() {
            const container = document.getElementById('customAssetsList');
            if (!container) return;
            container.innerHTML = '<p class="text-muted small">{{ t.loading or "Loading..." }}</p>';
            try {
                const res = await fetch(`${API_BASE}/customization/assets`, { credentials: 'include' });
                if (!res.ok) throw new Error('Failed to load assets');
                const data = await res.json();
                if (!data.assets || data.assets.length === 0) {
                    container.innerHTML = '<p class="text-muted small">{{ t.custom_assets_empty or "No files uploaded yet." }}</p>';
                    return;
                }
                container.innerHTML = `
                    <table class="admin-table">
                        <thead><tr><th>File</th><th>URL</th><th>Size</th><th></th></tr></thead>
                        <tbody>
                            ${data.assets.map(asset => `
                                <tr>
                                    <td class="text-break">${escapeHtml(asset.filename)}</td>
                                    <td>
                                        <code class="text-break small">${escapeHtml(asset.url)}</code>
                                        <button type="button" class="btn-admin-icon ms-1 js-copy-url" data-url="${escapeHtml(asset.url)}" title="{{ t.custom_assets_copy_url or 'Copy URL' }}">
                                            <span class="mi mi-sm">content_copy</span>
                                        </button>
                                    </td>
                                    <td class="text-nowrap">${formatBytes(asset.size)}</td>
                                    <td>
                                        <button type="button" class="btn-admin-outline btn-sm js-delete-asset" data-filename="${escapeHtml(asset.filename)}">
                                            <span class="mi mi-sm">delete</span>
                                        </button>
                                    </td>
                                </tr>
                            `).join('')}
                        </tbody>
                    </table>`;
            } catch (err) {
                container.innerHTML = `<p class="text-danger small">${escapeHtml(err?.message || 'Error loading assets')}</p>`;
            }
        }

        // Event delegation for dynamically rendered asset buttons
        document.getElementById('customAssetsList')?.addEventListener('click', async (e) => {
            const copyBtn = e.target.closest('.js-copy-url');
            if (copyBtn) {
                copyToClipboard(copyBtn.dataset.url);
                return;
            }
            const deleteBtn = e.target.closest('.js-delete-asset');
            if (deleteBtn) {
                const filename = deleteBtn.dataset.filename;
                if (!confirm(`Delete "${filename}"?`)) return;
                try {
                    const res = await fetch(`${API_BASE}/customization/assets/${encodeURIComponent(filename)}`, {
                        method: 'DELETE',
                        credentials: 'include',
                    });
                    if (!res.ok) throw new Error('Delete failed');
                    loadCustomAssets();
                } catch (err) {
                    alert(err?.message || 'Error deleting file');
                }
            }
        });

        const assetFileInput = document.getElementById('assetFileInput');
        const assetUploadStatus = document.getElementById('assetUploadStatus');

        if (assetFileInput) {
            assetFileInput.addEventListener('change', async () => {
                const files = Array.from(assetFileInput.files || []);
                if (!files.length) return;
                if (assetUploadStatus) {
                    assetUploadStatus.textContent = '...';
                    assetUploadStatus.className = 'admin-settings-status';
                }
                let errors = 0;
                for (const file of files) {
                    const formData = new FormData();
                    formData.append('file', file);
                    try {
                        const res = await fetch(`${API_BASE}/customization/assets`, {
                            method: 'POST',
                            credentials: 'include',
                            body: formData,
                        });
                        if (!res.ok) {
                            const data = await res.json().catch(() => ({}));
                            throw new Error(data.message || 'Upload failed');
                        }
                    } catch {
                        errors++;
                    }
                }
                if (assetUploadStatus) {
                    if (errors === 0) {
                        assetUploadStatus.textContent = '✓';
                        assetUploadStatus.classList.add('success');
                        setTimeout(() => {
                            assetUploadStatus.textContent = '';
                            assetUploadStatus.className = 'admin-settings-status';
                        }, 3000);
                    } else {
                        assetUploadStatus.textContent = `${errors} file(s) failed`;
                        assetUploadStatus.classList.add('error');
                    }
                }
                assetFileInput.value = '';
                loadCustomAssets();
            });
        }

        // Load assets when the Custom Assets accordion panel opens
        document.getElementById('collapseAssets')?.addEventListener('show.bs.collapse', loadCustomAssets);

        function collectAdminSettings() {
            const inputs = Array.from(document.querySelectorAll('[data-setting-key]'));
            const grouped = new Map();

            inputs.forEach(input => {
                const key = input.dataset.settingKey;
                const type = input.dataset.settingType || 'string';
                if (!key) return;

                if (type === 'csv') {
                    if (!grouped.has(key)) {
                        grouped.set(key, { key, type: 'string', options: [] });
                    }
                    if (input.checked) {
                        grouped.get(key).options.push(input.dataset.settingOption);
                    }
                    return;
                }

                let value = '';
                if (type === 'boolean') {
                    value = input.checked ? 'true' : 'false';
                } else {
                    value = input.value ?? '';
                }
                grouped.set(key, { key, value: String(value), type });
            });

            return Array.from(grouped.values()).map(entry => {
                if (entry.options) {
                    return { key: entry.key, value: entry.options.join(','), type: 'string' };
                }
                return entry;
            });
        }

        function updateCreateUserDefaultQuota(settings) {
            const defaultQuotaSetting = settings.find(setting => setting.key === 'DEFAULT_QUOTA');
            if (!defaultQuotaSetting) return;
            const quotaInput = document.querySelector('#createUserForm [name="quota_mb"]');
            if (!quotaInput) return;
            quotaInput.value = defaultQuotaSetting.value ?? '';
        }

        // Load stats
        async function loadStats() {
            try {
                const res = await fetch(`${API_BASE}/stats`, { credentials: 'include' });
                if (!res.ok) throw new Error('Failed to load stats');
                const data = await res.json();

                document.getElementById('stat-totalUsers').textContent = data.totalUsers ?? '-';
                document.getElementById('stat-activeUsers').textContent = data.activeUsers ?? '-';
                document.getElementById('stat-totalProjects').textContent = data.totalProjects ?? '-';
                document.getElementById('stat-activeProjects').textContent = data.activeProjects ?? '-';
            } catch (err) {
                console.error('Failed to load stats:', err);
            }
        }

        // Load system info
        async function loadSystemInfo() {
            const container = document.getElementById('system-info-content');
            try {
                const res = await fetch(`${API_BASE}/system-info`, { credentials: 'include' });
                if (!res.ok) throw new Error('Failed to load system info');
                const data = await res.json();
                container.innerHTML = renderSystemInfo(data);
            } catch (err) {
                console.error('Failed to load system info:', err);
                container.innerHTML = `<div class="empty-state"><span class="mi">error</span><p>${T.error || 'Error loading system info'}</p></div>`;
            }
        }

        function formatBytes(bytes) {
            if (bytes === 0) return '0 B';
            const k = 1024;
            const sizes = ['B', 'KB', 'MB', 'GB', 'TB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
        }

        function formatUptime(seconds) {
            const days = Math.floor(seconds / 86400);
            const hours = Math.floor((seconds % 86400) / 3600);
            const mins = Math.floor((seconds % 3600) / 60);
            if (days > 0) return `${days}d ${hours}h ${mins}m`;
            if (hours > 0) return `${hours}h ${mins}m`;
            return `${mins}m`;
        }

        function renderSystemInfo(info) {
            const diskUsagePercent = info.disk.total > 0
                ? Math.round((1 - info.disk.available / info.disk.total) * 100)
                : 0;
            const memUsagePercent = info.memory.total > 0
                ? Math.round((info.memory.used / info.memory.total) * 100)
                : 0;

            return `
                <div class="system-info-grid">
                    <div class="system-info-section">
                        <h6><span class="mi mi-sm">memory</span> Runtime</h6>
                        <div class="system-info-item">
                            <span class="label">Engine</span>
                            <span class="value">${info.runtime.name} ${info.runtime.version}</span>
                        </div>
                        <div class="system-info-item">
                            <span class="label">Platform</span>
                            <span class="value">${info.runtime.platform} (${info.runtime.arch})</span>
                        </div>
                    </div>
                    <div class="system-info-section">
                        <h6><span class="mi mi-sm">storage</span> Database</h6>
                        <div class="system-info-item">
                            <span class="label">Engine</span>
                            <span class="value">${info.database.engine}</span>
                        </div>
                        <div class="system-info-item">
                            <span class="label">Version</span>
                            <span class="value">${info.database.version}</span>
                        </div>
                        ${info.database.path ? `<div class="system-info-item"><span class="label">Path</span><span class="value" title="${info.database.path}">${info.database.path.length > 30 ? '...' + info.database.path.slice(-27) : info.database.path}</span></div>` : ''}
                        ${info.database.host ? `<div class="system-info-item"><span class="label">Host</span><span class="value">${info.database.host}:${info.database.port}</span></div>` : ''}
                    </div>
                    <div class="system-info-section">
                        <h6><span class="mi mi-sm">apps</span> Application</h6>
                        <div class="system-info-item">
                            <span class="label">Version</span>
                            <span class="value">${info.application.version}</span>
                        </div>
                        <div class="system-info-item">
                            <span class="label">Environment</span>
                            <span class="value ${info.application.environment === 'prod' ? 'success' : 'warning'}">${info.application.environment}</span>
                        </div>
                        <div class="system-info-item">
                            <span class="label">Port</span>
                            <span class="value">${info.application.port}</span>
                        </div>
                    </div>
                    <div class="system-info-section">
                        <h6><span class="mi mi-sm">developer_board</span> Memory</h6>
                        <div class="system-info-item">
                            <span class="label">System RAM</span>
                            <span class="value">${formatBytes(info.memory.used)} / ${formatBytes(info.memory.total)} (${memUsagePercent}%)</span>
                        </div>
                        <div class="system-info-item">
                            <span class="label">Heap Used</span>
                            <span class="value">${formatBytes(info.memory.heapUsed)} / ${formatBytes(info.memory.heapTotal)}</span>
                        </div>
                    </div>
                    <div class="system-info-section">
                        <h6><span class="mi mi-sm">computer</span> Operating System</h6>
                        <div class="system-info-item">
                            <span class="label">Platform</span>
                            <span class="value">${info.os.platform}</span>
                        </div>
                        <div class="system-info-item">
                            <span class="label">Hostname</span>
                            <span class="value">${info.os.hostname}</span>
                        </div>
                        <div class="system-info-item">
                            <span class="label">CPUs</span>
                            <span class="value">${info.os.cpus}</span>
                        </div>
                        <div class="system-info-item">
                            <span class="label">Uptime</span>
                            <span class="value">${formatUptime(info.os.uptime)}</span>
                        </div>
                    </div>
                    <div class="system-info-section">
                        <h6><span class="mi mi-sm">folder</span> Disk (${info.disk.path})</h6>
                        ${info.disk.error ? `<div class="system-info-item"><span class="label">Status</span><span class="value warning">${info.disk.error}</span></div>` : `
                        <div class="system-info-item">
                            <span class="label">Available</span>
                            <span class="value">${formatBytes(info.disk.available)} / ${formatBytes(info.disk.total)} (${diskUsagePercent}% used)</span>
                        </div>
                        `}
                        <div class="system-info-item">
                            <span class="label">Docker</span>
                            <span class="value ${info.docker.isDocker ? 'success' : ''}">${info.docker.isDocker ? 'Yes' : 'No'}${info.docker.containerId ? ` (${info.docker.containerId.slice(0, 12)})` : ''}</span>
                        </div>
                    </div>
                </div>
            `;
        }

        // Load users
        async function loadUsers() {
            const tbody = document.getElementById('usersTableBody');
            const loading = document.getElementById('usersLoading');

            loading.classList.add('active');

            try {
                const search = document.getElementById('userSearch').value;
                const url = new URL(`${API_BASE}/users`, window.location.origin);
                url.searchParams.set('limit', usersLimit);
                url.searchParams.set('offset', usersOffset);
                url.searchParams.set('sortBy', sortBy);
                url.searchParams.set('sortOrder', sortOrder);
                if (search) url.searchParams.set('search', search);

                const res = await fetch(url, { credentials: 'include' });
                if (!res.ok) throw new Error('Failed to load users');
                const data = await res.json();

                usersTotal = data.total;
                tbody.innerHTML = '';

                data.users.forEach(user => {
                    const roles = user.roles.map(r => {
                        const cls = r === 'ROLE_ADMIN' ? 'badge-admin' : r === 'ROLE_EDITOR' ? 'badge-editor' : 'badge-user';
                        return `<span class="badge-role ${cls}">${r.replace('ROLE_', '')}</span>`;
                    }).join(' ');

                    const statusCls = user.is_active ? 'badge-active' : 'badge-inactive';
                    const statusText = user.is_active ? T.active : T.inactive;
                    const isChecked = selectedUserIds.has(user.id) ? 'checked' : '';
                    const isAdminTarget = user.roles.includes('ROLE_ADMIN');
                    const isSelfUser = Number(user.id) === CURRENT_ADMIN_USER_ID;
                    const canImpersonate = !isAdminTarget && !isSelfUser;
                    const impersonateButtonTitle = isAdminTarget
                        ? T.cannot_impersonate_admin
                        : (isSelfUser ? T.cannot_impersonate_self : T.log_in_as);
                    const safeImpersonateTitle = String(impersonateButtonTitle || '').replace(/"/g, '&quot;');
                    const impersonateButton = canImpersonate
                        ? `<button class="btn-admin-outline" data-action="impersonate" onclick='impersonateUser(${user.id}, ${JSON.stringify(user.email || '')})' title="${safeImpersonateTitle}">
                                <span class="mi mi-sm">login</span>
                           </button>`
                        : `<button class="btn-admin-outline" data-action="impersonate" disabled title="${safeImpersonateTitle}">
                                <span class="mi mi-sm">login</span>
                           </button>`;

                    // Build quota display with progress bar
                    let quotaHTML = '';
                    if (user.quota_mb == null) {
                        quotaHTML = '<span class="quota-unlimited">' + T.unlimited + '</span>';
                    } else {
                        const usedMB = user.storage_used_mb || 0;
                        const quotaMB = user.quota_mb;
                        const percentage = quotaMB > 0 ? Math.min(Math.round((usedMB / quotaMB) * 100), 100) : 0;

                        // Determine color class based on usage
                        let fillClass = '';
                        if (percentage >= 90) {
                            fillClass = 'danger';
                        } else if (percentage >= 75) {
                            fillClass = 'warning';
                        }

                        quotaHTML = `
                            <div class="quota-container">
                                <div class="quota-text">
                                    <span style="font-weight: 500;">${usedMB} / ${quotaMB} MB</span>
                                    <span>${percentage}%</span>
                                </div>
                                <div class="quota-bar">
                                    <div class="quota-fill ${fillClass}" style="width: ${percentage}%"></div>
                                </div>
                            </div>
                        `;
                    }

                    const tr = document.createElement('tr');
                    tr.dataset.userId = user.id;
                    tr.innerHTML = `
                        <td>
                            <input type="checkbox" class="bulk-checkbox user-checkbox" data-user-id="${user.id}" ${isChecked}>
                        </td>
                        <td style="font-weight: 600; color: var(--admin-text-muted);">#${user.id}</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="user-avatar user-avatar-sm">${(user.email[0] || 'U').toUpperCase()}</div>
                                <span style="font-weight: 500;">${user.email}</span>
                            </div>
                        </td>
                        <td>${roles}</td>
                        <td>${quotaHTML}</td>
                        <td><span class="badge-role ${statusCls}">${statusText}</span></td>
                        <td>
                            <div class="d-flex gap-1">
                                <button class="btn-admin-outline" onclick="editUser(${user.id})" title="{{ t.edit or 'Edit' }}">
                                    <span class="mi mi-sm">edit</span>
                                </button>
                                ${impersonateButton}
                            </div>
                        </td>
                    `;
                    tbody.appendChild(tr);
                });

                // Bind checkbox events
                bindUserCheckboxes();

                // Update sort icons
                updateSortIcons();

                updatePagination();
            } catch (err) {
                console.error('Failed to load users:', err);
                tbody.innerHTML = `<tr><td colspan="7" class="text-center" style="padding: 2rem; color: var(--system-red);">${T.error_loading}</td></tr>`;
            } finally {
                loading.classList.remove('active');
            }
        }

        function updatePagination() {
            const paginationEl = document.getElementById('usersPagination');
            const prevBtn = document.getElementById('usersPrevBtn');
            const nextBtn = document.getElementById('usersNextBtn');

            const start = usersTotal > 0 ? usersOffset + 1 : 0;
            const end = Math.min(usersOffset + usersLimit, usersTotal);
            paginationEl.textContent = `${start}-${end} of ${usersTotal}`;

            prevBtn.disabled = usersOffset === 0;
            nextBtn.disabled = usersOffset + usersLimit >= usersTotal;
        }

        document.getElementById('usersPrevBtn').addEventListener('click', () => {
            usersOffset = Math.max(0, usersOffset - usersLimit);
            loadUsers();
        });

        document.getElementById('usersNextBtn').addEventListener('click', () => {
            usersOffset += usersLimit;
            loadUsers();
        });

        // Sort functionality
        function updateSortIcons() {
            document.querySelectorAll('.admin-table th.sortable[data-sort]').forEach(th => {
                const col = th.dataset.sort;
                const icon = th.querySelector('.sort-icon');

                if (col === sortBy) {
                    th.classList.add('sorted');
                    icon.textContent = sortOrder === 'asc' ? 'expand_less' : 'expand_more';
                } else {
                    th.classList.remove('sorted');
                    icon.textContent = 'unfold_more';
                }
            });
        }

        document.querySelectorAll('.admin-table th.sortable[data-sort]').forEach(th => {
            th.addEventListener('click', () => {
                const col = th.dataset.sort;
                if (sortBy === col) {
                    sortOrder = sortOrder === 'asc' ? 'desc' : 'asc';
                } else {
                    sortBy = col;
                    sortOrder = 'asc';
                }
                usersOffset = 0;
                loadUsers();
            });
        });

        // Bulk selection functions
        function bindUserCheckboxes() {
            document.querySelectorAll('.user-checkbox').forEach(cb => {
                cb.addEventListener('change', (e) => {
                    const userId = parseInt(e.target.dataset.userId);
                    if (e.target.checked) {
                        selectedUserIds.add(userId);
                    } else {
                        selectedUserIds.delete(userId);
                    }
                    updateBulkActionsBar();
                    updateSelectAllCheckbox();
                });
            });
        }

        function updateBulkActionsBar() {
            const bar = document.getElementById('bulkActionsBar');
            const countEl = document.getElementById('selectedCount');
            const count = selectedUserIds.size;

            if (count > 0) {
                bar.classList.add('active');
                countEl.textContent = `${count} ${T.selected}`;
            } else {
                bar.classList.remove('active');
            }
        }

        function updateSelectAllCheckbox() {
            const selectAll = document.getElementById('selectAllUsers');
            const checkboxes = document.querySelectorAll('.user-checkbox');
            const checkedCount = document.querySelectorAll('.user-checkbox:checked').length;

            if (checkboxes.length === 0) {
                selectAll.checked = false;
                selectAll.indeterminate = false;
            } else if (checkedCount === 0) {
                selectAll.checked = false;
                selectAll.indeterminate = false;
            } else if (checkedCount === checkboxes.length) {
                selectAll.checked = true;
                selectAll.indeterminate = false;
            } else {
                selectAll.checked = false;
                selectAll.indeterminate = true;
            }
        }

        // Select all checkbox
        document.getElementById('selectAllUsers').addEventListener('change', (e) => {
            const checkboxes = document.querySelectorAll('.user-checkbox');
            checkboxes.forEach(cb => {
                cb.checked = e.target.checked;
                const userId = parseInt(cb.dataset.userId);
                if (e.target.checked) {
                    selectedUserIds.add(userId);
                } else {
                    selectedUserIds.delete(userId);
                }
            });
            updateBulkActionsBar();
        });

        // Clear selection button
        document.getElementById('clearSelectionBtn').addEventListener('click', () => {
            selectedUserIds.clear();
            document.querySelectorAll('.user-checkbox').forEach(cb => cb.checked = false);
            document.getElementById('selectAllUsers').checked = false;
            document.getElementById('selectAllUsers').indeterminate = false;
            updateBulkActionsBar();
        });

        // Bulk delete button
        document.getElementById('bulkDeleteBtn').addEventListener('click', async () => {
            const count = selectedUserIds.size;
            if (count === 0) return;

            const confirmMsg = T.confirm_delete_bulk.replace('{count}', count);
            if (!confirm(confirmMsg)) return;

            const btn = document.getElementById('bulkDeleteBtn');
            const originalText = btn.innerHTML;
            btn.innerHTML = `<span class="mi mi-sm">hourglass_empty</span> ${T.deleting}`;
            btn.disabled = true;

            let deleted = 0;
            let errors = [];

            for (const userId of selectedUserIds) {
                try {
                    const res = await fetch(`${API_BASE}/users/${userId}`, {
                        method: 'DELETE',
                        credentials: 'include'
                    });

                    if (res.ok) {
                        deleted++;
                    } else {
                        const data = await res.json();
                        errors.push(`User ${userId}: ${data.message || 'Failed'}`);
                    }
                } catch (err) {
                    errors.push(`User ${userId}: ${err.message}`);
                }
            }

            btn.innerHTML = originalText;
            btn.disabled = false;

            if (errors.length > 0) {
                alert(`Deleted ${deleted} users. Errors:\n${errors.join('\n')}`);
            }

            // Clear selection and reload
            selectedUserIds.clear();
            document.getElementById('selectAllUsers').checked = false;
            updateBulkActionsBar();
            loadUsers();
