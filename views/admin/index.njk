<!DOCTYPE html>
<html lang="{{ locale or 'en' }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="noindex">
    <title>{{ t.admin_panel or 'Admin Panel' }} - eXeLearning</title>
    <link rel="icon" href="{{ basePath }}/favicon.ico">
    <link rel="stylesheet" href="{{ basePath }}/libs/bootstrap/bootstrap.min.css">
    <link rel="stylesheet" href="{{ basePath }}/style/workarea/main.css">
    <style>
        :root {
            --admin-sidebar-width: 260px;
            --admin-primary: var(--brand-primary, #0BA1A1);
            --admin-primary-dark: var(--brand-primary-dark, #107275);
            --admin-primary-light: var(--brand-primary-100, #CCFBF7);
            --admin-bg: var(--gray-50, #f9fafb);
            --admin-card-bg: #ffffff;
            --admin-border: var(--gray-200, #e5e7eb);
            --admin-text: var(--gray-700, #374151);
            --admin-text-muted: var(--gray-500, #696d75);
            --admin-radius: 12px;
            --admin-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
            --admin-shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
        }

        * {
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            overflow: hidden;
        }

        body {
            background-color: var(--admin-bg);
            font-family: var(--body-text-font, 'Catamaran', system-ui, -apple-system, sans-serif);
            color: var(--admin-text);
            margin: 0;
            padding: 0;
        }

        /* Material Icons */
        .mi {
            font-family: var(--icons-ff, 'Material icons Round');
            font-weight: normal;
            font-style: normal;
            font-size: 20px;
            line-height: 1;
            letter-spacing: normal;
            text-transform: none;
            display: inline-block;
            white-space: nowrap;
            word-wrap: normal;
            direction: ltr;
            -webkit-font-smoothing: antialiased;
            vertical-align: middle;
        }

        .mi-sm { font-size: 16px; }
        .mi-lg { font-size: 24px; }
        .mi-xl { font-size: 32px; }

        /* Sidebar */
        .admin-sidebar {
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            width: var(--admin-sidebar-width);
            background: var(--admin-card-bg);
            border-right: 1px solid var(--admin-border);
            z-index: 100;
            overflow-y: auto;
            overflow-x: hidden;
            display: flex;
            flex-direction: column;
        }

        .admin-sidebar-header {
            padding: 1.25rem;
            background: linear-gradient(135deg, var(--admin-primary) 0%, var(--admin-primary-dark) 100%);
            color: white;
        }

        .admin-sidebar-header h5 {
            margin: 0;
            font-weight: 700;
            font-size: 1.1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            white-space: nowrap;
        }

        .admin-sidebar-header small {
            opacity: 0.85;
            display: block;
            margin-top: 0.25rem;
            font-size: 0.8rem;
        }

        .admin-nav {
            padding: 1rem 0;
            flex: 1;
        }

        .admin-nav-section {
            padding: 0.5rem 1rem 0.25rem;
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--admin-text-muted);
        }

        .admin-nav-link {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem 1.25rem;
            color: var(--admin-text);
            text-decoration: none;
            transition: all 0.2s ease;
            border-left: 3px solid transparent;
            font-weight: 500;
            white-space: nowrap;
        }

        .admin-nav-link:hover {
            background: var(--admin-primary-light);
            color: var(--admin-primary);
        }

        .admin-nav-link.active {
            background: var(--admin-primary-light);
            color: var(--admin-primary);
            border-left-color: var(--admin-primary);
        }

        .admin-nav-link .mi {
            color: inherit;
            opacity: 0.7;
        }

        .admin-nav-link.active .mi,
        .admin-nav-link:hover .mi {
            opacity: 1;
        }

        .admin-nav-divider {
            border-top: 1px solid var(--admin-border);
            margin: 0.75rem 1rem;
        }

        /* Main content */
        .admin-main {
            margin-left: var(--admin-sidebar-width);
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .admin-header {
            background: var(--admin-card-bg);
            border-bottom: 1px solid var(--admin-border);
            padding: 1rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 50;
        }

        .admin-header-title {
            font-size: 1.25rem;
            font-weight: 700;
            margin: 0;
            color: var(--admin-text);
        }

        .admin-header-user {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .admin-content {
            padding: 1.5rem;
            flex: 1;
            overflow-y: auto;
        }

        /* Cards */
        .admin-card {
            background: var(--admin-card-bg);
            border-radius: var(--admin-radius);
            border: 1px solid var(--admin-border);
            box-shadow: var(--admin-shadow);
            overflow: hidden;
        }

        .admin-card-header {
            padding: 1rem 1.25rem;
            border-bottom: 1px solid var(--admin-border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: var(--gray-50, #f9fafb);
        }

        .admin-card-header h5 {
            margin: 0;
            font-weight: 600;
            font-size: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .admin-card-body {
            padding: 1.25rem;
        }

        /* Stats cards */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1.5rem;
            margin-bottom: 2rem;
            max-width: 1200px;
        }

        @media (max-width: 1200px) {
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 600px) {
            .stats-grid {
                grid-template-columns: 1fr;
            }
        }

        .stats-card {
            background: var(--admin-card-bg);
            border-radius: var(--admin-radius);
            border: 1px solid var(--admin-border);
            padding: 1.25rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            box-shadow: var(--admin-shadow);
            transition: all 0.2s ease;
        }

        .stats-card:hover {
            box-shadow: var(--admin-shadow-lg);
            transform: translateY(-2px);
        }

        .stats-icon {
            width: 56px;
            height: 56px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .stats-icon .mi {
            font-size: 28px;
        }

        .stats-icon.primary {
            background: linear-gradient(135deg, var(--admin-primary-light) 0%, rgba(11, 161, 161, 0.2) 100%);
            color: var(--admin-primary);
        }

        .stats-icon.success {
            background: linear-gradient(135deg, #d1fae5 0%, rgba(16, 185, 129, 0.2) 100%);
            color: #059669;
        }

        .stats-icon.info {
            background: linear-gradient(135deg, #dbeafe 0%, rgba(59, 130, 246, 0.2) 100%);
            color: #2563eb;
        }

        .stats-icon.warning {
            background: linear-gradient(135deg, #fef3c7 0%, rgba(245, 158, 11, 0.2) 100%);
            color: #d97706;
        }

        .stats-content {
            flex: 1;
            min-width: 0;
        }

        .stats-value {
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--admin-text);
            line-height: 1.2;
        }

        .stats-label {
            color: var(--admin-text-muted);
            font-size: 0.85rem;
            font-weight: 500;
        }

        /* User avatar */
        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--admin-primary) 0%, var(--admin-primary-dark) 100%);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 1rem;
            flex-shrink: 0;
        }

        .user-avatar-sm {
            width: 32px;
            height: 32px;
            font-size: 0.85rem;
        }

        /* Badges */
        .badge-role {
            font-size: 0.7rem;
            font-weight: 600;
            padding: 0.25rem 0.5rem;
            border-radius: 4px;
            text-transform: uppercase;
            letter-spacing: 0.02em;
        }

        .badge-admin {
            background: linear-gradient(135deg, #fecaca 0%, #fee2e2 100%);
            color: #dc2626;
        }

        .badge-user {
            background: var(--gray-100, #f3f4f6);
            color: var(--gray-600, #4b5563);
        }

        .badge-editor {
            background: linear-gradient(135deg, #dbeafe 0%, #eff6ff 100%);
            color: #2563eb;
        }

        .badge-active {
            background: linear-gradient(135deg, #d1fae5 0%, #ecfdf5 100%);
            color: #059669;
        }

        .badge-inactive {
            background: var(--gray-100, #f3f4f6);
            color: var(--gray-500, #696d75);
        }

        .badge-archived {
            background: var(--gray-100, #f3f4f6);
            color: var(--gray-600, #4b5563);
        }

        .badge-deleted {
            background: linear-gradient(135deg, #fecaca 0%, #fee2e2 100%);
            color: #dc2626;
        }

        .admin-filter-group {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            align-items: center;
        }

        /* Table */
        .admin-table-wrapper {
            overflow-x: auto;
        }

        .admin-table {
            width: 100%;
            border-collapse: collapse;
        }

        .admin-table th {
            background: var(--gray-50, #f9fafb);
            padding: 0.75rem 1rem;
            text-align: left;
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.02em;
            color: var(--admin-text-muted);
            border-bottom: 1px solid var(--admin-border);
        }

        .admin-table th.sortable {
            cursor: pointer;
            user-select: none;
            transition: background 0.2s ease;
        }

        .admin-table th.sortable:hover {
            background: var(--gray-100, #f3f4f6);
            color: var(--admin-primary);
        }

        .admin-table th.sortable .sort-icon {
            opacity: 0.3;
            transition: opacity 0.2s;
        }

        .admin-table th.sortable:hover .sort-icon,
        .admin-table th.sortable.sorted .sort-icon {
            opacity: 1;
        }

        .admin-table th.sortable.sorted {
            color: var(--admin-primary);
        }

        .admin-table td {
            padding: 0.875rem 1rem;
            border-bottom: 1px solid var(--admin-border);
            vertical-align: middle;
        }

        .admin-table tbody tr:hover {
            background: var(--gray-50, #f9fafb);
        }

        .admin-table tbody tr:last-child td {
            border-bottom: none;
        }

        /* Theme row styles - distinguish base from site themes */
        .admin-table tbody tr.theme-row-base {
            background: linear-gradient(to right, rgba(59, 130, 246, 0.08), transparent);
            border-left: 3px solid var(--primary, #3b82f6);
        }
        .admin-table tbody tr.theme-row-base:hover {
            background: linear-gradient(to right, rgba(59, 130, 246, 0.12), var(--gray-50, #f9fafb));
        }
        .admin-table tbody tr.theme-row-site {
            border-left: 3px solid transparent;
        }

        .ext-toolbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
            padding: 0.5rem 0;
            gap: 1rem;
        }

        .ext-toolbar-left {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .ext-toolbar-left label {
            font-weight: 500;
            color: var(--admin-text-light);
        }

        /* Toggle Switch */
        .toggle-switch {
            position: relative;
            display: inline-block;
            width: 40px;
            height: 22px;
        }

        .toggle-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .toggle-slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #ccc;
            transition: 0.3s;
            border-radius: 22px;
        }

        .toggle-slider:before {
            position: absolute;
            content: "";
            height: 16px;
            width: 16px;
            left: 3px;
            bottom: 3px;
            background-color: white;
            transition: 0.3s;
            border-radius: 50%;
        }

        .toggle-switch input:checked + .toggle-slider {
            background-color: var(--admin-primary);
        }

        .toggle-switch input:checked + .toggle-slider:before {
            transform: translateX(18px);
        }

        /* Small buttons */
        .btn-admin-sm {
            padding: 0.25rem 0.5rem;
            font-size: 0.75rem;
            border-radius: 4px;
            border: 1px solid var(--admin-border);
            background: white;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
            transition: all 0.2s ease;
        }

        .btn-admin-sm:hover {
            background: var(--gray-50);
        }

        .btn-admin-sm.btn-danger {
            color: #dc3545;
            border-color: #dc3545;
        }

        .btn-admin-sm.btn-danger:hover {
            background: #dc3545;
            color: white;
        }

        .btn-admin-sm:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        /* Badge */
        .badge {
            display: inline-block;
            padding: 0.25rem 0.5rem;
            font-size: 0.75rem;
            font-weight: 500;
            border-radius: 4px;
        }

        .badge-success {
            background-color: #d4edda;
            color: #155724;
        }

        /* Spin animation */
        @keyframes mi-spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .mi-spin {
            animation: mi-spin 1s linear infinite;
        }

        /* Buttons */
        .btn-admin-primary {
            background: linear-gradient(135deg, var(--admin-primary) 0%, var(--admin-primary-dark) 100%);
            color: white;
            border: none;
            padding: 0.5rem 1rem;
            border-radius: 8px;
            font-weight: 600;
            font-size: 0.875rem;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .btn-admin-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(11, 161, 161, 0.3);
            color: white;
        }

        .btn-admin-outline {
            background: transparent;
            color: var(--admin-text);
            border: 1px solid var(--admin-border);
            padding: 0.4rem 0.75rem;
            border-radius: 8px;
            font-weight: 500;
            font-size: 0.8rem;
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .btn-admin-outline:hover {
            background: var(--gray-50, #f9fafb);
            border-color: var(--admin-primary);
            color: var(--admin-primary);
        }

        .btn-admin-danger {
            background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
            color: white;
            border: none;
        }

        .btn-admin-danger:hover {
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
            color: white;
        }

        /* Form controls */
        .admin-input {
            border: 1px solid var(--admin-border);
            border-radius: 8px;
            padding: 0.5rem 0.75rem;
            font-size: 0.875rem;
            transition: all 0.2s ease;
            width: 100%;
        }

        .admin-input:focus {
            outline: none;
            border-color: var(--admin-primary);
            box-shadow: 0 0 0 3px var(--admin-primary-light);
        }

        .admin-input[readonly] {
            background: var(--gray-100, #f3f4f6);
        }

        .admin-settings-group {
            margin-bottom: 1.5rem;
        }

        .admin-settings-group h6 {
            font-weight: 700;
            margin-bottom: 0.75rem;
        }

        .admin-settings-actions {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1.5rem;
        }

        .admin-settings-status {
            font-size: 0.8rem;
            color: var(--admin-text-muted);
        }

        .admin-settings-status.success {
            color: #16a34a;
        }

        .admin-settings-status.error {
            color: #dc2626;
        }

        .admin-settings-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 1rem;
        }

        .admin-field label {
            display: block;
            font-size: 0.8rem;
            font-weight: 600;
            margin-bottom: 0.25rem;
        }

        .admin-field small {
            display: block;
            margin-top: 0.35rem;
            color: var(--admin-text-muted);
            font-size: 0.75rem;
        }

        /* Maintenance banner */
        .maintenance-banner {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.75rem 1rem;
            margin-bottom: 1.5rem;
            background: #fff7e6;
            border: 1px solid #f6d28b;
            border-radius: var(--admin-radius);
            color: #7a5400;
            font-size: 0.9rem;
        }

        /* Maintenance status card */
        .maintenance-status-card {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1.25rem 1.5rem;
            margin-bottom: 1.5rem;
            border-radius: var(--admin-radius);
            border: 1px solid;
        }

        .maintenance-status-inactive {
            background: #f0fdf4;
            border-color: #bbf7d0;
            color: #166534;
        }

        .maintenance-status-active {
            background: #fff7e6;
            border-color: #f6d28b;
            color: #7a5400;
        }

        .maintenance-status-icon .mi {
            font-size: 32px;
        }

        .maintenance-status-info strong {
            display: block;
            font-size: 1rem;
            margin-bottom: 0.25rem;
        }

        .maintenance-status-info p {
            margin: 0;
            font-size: 0.85rem;
            opacity: 0.85;
        }

        /* Section visibility */
        .admin-section {
            display: none;
        }

        .admin-section.active {
            display: block;
        }

        /* Loading */
        .loading-overlay {
            display: none;
            padding: 3rem;
            text-align: center;
        }

        .loading-overlay.active {
            display: block;
        }

        .spinner {
            width: 40px;
            height: 40px;
            border: 3px solid var(--admin-border);
            border-top-color: var(--admin-primary);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
            margin: 0 auto 1rem;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Pagination */
        .pagination-wrapper {
            padding: 1rem 1.25rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-top: 1px solid var(--admin-border);
            background: var(--gray-50, #f9fafb);
        }

        .pagination-info {
            font-size: 0.85rem;
            color: var(--admin-text-muted);
        }

        .pagination-btns {
            display: flex;
            gap: 0.5rem;
        }

        /* Modal */
        .modal-content {
            border-radius: var(--admin-radius);
            border: none;
            box-shadow: var(--admin-shadow-lg);
        }

        .modal-header {
            background: linear-gradient(135deg, var(--admin-primary) 0%, var(--admin-primary-dark) 100%);
            color: white;
            border-radius: var(--admin-radius) var(--admin-radius) 0 0;
            padding: 1rem 1.25rem;
        }

        .modal-header .modal-title {
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .modal-header .btn-close {
            filter: brightness(0) invert(1);
            opacity: 0.8;
        }

        .modal-header .btn-close:hover {
            opacity: 1;
        }

        .modal-body {
            padding: 1.5rem;
        }

        .modal-footer {
            padding: 1rem 1.5rem;
            border-top: 1px solid var(--admin-border);
        }

        /* Form groups */
        .form-group {
            margin-bottom: 1rem;
        }

        .form-group label {
            display: block;
            font-weight: 600;
            font-size: 0.85rem;
            margin-bottom: 0.5rem;
            color: var(--admin-text);
        }

        .form-check-custom {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 0;
        }

        .form-check-custom input[type="checkbox"] {
            width: 18px;
            height: 18px;
            accent-color: var(--admin-primary);
        }

        .form-switch-custom {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        /* Responsive */
        @media (max-width: 991.98px) {
            .admin-sidebar {
                transform: translateX(-100%);
                transition: transform 0.3s ease;
                box-shadow: var(--admin-shadow-lg);
            }

            .admin-sidebar.show {
                transform: translateX(0);
            }

            .admin-main {
                margin-left: 0;
            }

            .sidebar-overlay {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(0, 0, 0, 0.5);
                z-index: 99;
            }

            .sidebar-overlay.show {
                display: block;
            }
        }

        /* Empty state */
        .empty-state {
            padding: 3rem;
            text-align: center;
            color: var(--admin-text-muted);
        }

        .empty-state .mi {
            font-size: 48px;
            margin-bottom: 1rem;
            opacity: 0.5;
        }

        /* Bulk actions toolbar */
        .bulk-actions-bar {
            display: none;
            padding: 0.75rem 1.25rem;
            background: linear-gradient(135deg, var(--admin-primary-light) 0%, rgba(11, 161, 161, 0.1) 100%);
            border-bottom: 1px solid var(--admin-primary);
            align-items: center;
            gap: 1rem;
        }

        .bulk-actions-bar.active {
            display: flex;
        }

        .bulk-actions-bar .selected-count {
            font-weight: 600;
            color: var(--admin-primary-dark);
        }

        .bulk-checkbox {
            width: 18px;
            height: 18px;
            accent-color: var(--admin-primary);
            cursor: pointer;
        }

        /* Storage quota progress bar */
        .quota-container {
            min-width: 180px;
        }

        .quota-text {
            font-size: 0.75rem;
            color: var(--admin-text-muted);
            margin-bottom: 0.25rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .quota-bar {
            width: 100%;
            height: 8px;
            background: var(--gray-200, #e5e7eb);
            border-radius: 4px;
            overflow: hidden;
            position: relative;
        }

        .quota-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--admin-primary) 0%, var(--admin-primary-dark) 100%);
            border-radius: 4px;
            transition: width 0.3s ease;
        }

        .quota-fill.warning {
            background: linear-gradient(90deg, #f59e0b 0%, #d97706 100%);
        }

        .quota-fill.danger {
            background: linear-gradient(90deg, #ef4444 0%, #dc2626 100%);
        }

        .quota-unlimited {
            font-size: 0.75rem;
            color: var(--admin-text-muted);
            font-style: italic;
        }

        /* System Info */
        .system-info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1rem;
        }

        .system-info-section {
            background: var(--admin-bg);
            border-radius: 8px;
            padding: 1rem;
        }

        .system-info-section h6 {
            margin: 0 0 0.75rem 0;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--admin-primary);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .system-info-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.375rem 0;
            font-size: 0.875rem;
            border-bottom: 1px solid var(--admin-border);
        }

        .system-info-item:last-child {
            border-bottom: none;
        }

        .system-info-item .label {
            color: var(--admin-text-muted);
        }

        .system-info-item .value {
            font-weight: 500;
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
            font-size: 0.8125rem;
        }

        .system-info-item .value.success {
            color: #059669;
        }

        .system-info-item .value.warning {
            color: #d97706;
        }

        .system-info-loading {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            color: var(--admin-text-muted);
        }
        .admin-code-textarea {
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
            font-size: 0.85rem;
            resize: vertical;
            min-height: 200px;
        }
        .admin-code-example {
            margin-top: 0.75rem;
            background: var(--admin-bg, #f8f9fa);
            border: 1px solid var(--admin-border, #dee2e6);
            border-radius: 6px;
            overflow: hidden;
        }
        .admin-code-example summary {
            padding: 0.4rem 0.75rem;
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--admin-text-muted, #6c757d);
            cursor: pointer;
            user-select: none;
        }
        .admin-code-example pre {
            margin: 0;
            padding: 0.75rem;
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
            font-size: 0.8rem;
            line-height: 1.5;
            overflow-x: auto;
            border-top: 1px solid var(--admin-border, #dee2e6);
        }
        .admin-favicon-preview {
            border: 1px solid var(--admin-border, #dee2e6);
            border-radius: 4px;
            object-fit: contain;
            background: var(--admin-bg, #f8f9fa);
        }
        .btn-admin-icon {
            background: none;
            border: none;
            padding: 0.25rem;
            cursor: pointer;
            color: var(--admin-text-muted, #6c757d);
            border-radius: 4px;
            vertical-align: middle;
        }
        .btn-admin-icon:hover {
            background: var(--admin-bg, #f8f9fa);
            color: var(--admin-text, #374151);
        }
        .admin-file-input-sm {
            max-width: 300px;
        }
        .admin-file-input-sm::file-selector-button {
            margin-top: 0;
        }
        .accordion-button:not(.collapsed) {
            background-color: var(--admin-primary-light);
            color: var(--bs-accordion-btn-color);
        }
    </style>
</head>
<body>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- Sidebar -->
    <nav class="admin-sidebar" id="adminSidebar">
        <div class="admin-sidebar-header">
            <h5>
                <span class="mi">admin_panel_settings</span>
                {{ t.admin_panel or 'Admin Panel' }}
            </h5>
            <small>eXeLearning {{ version }}</small>
        </div>
        <div class="admin-nav">
            <div class="admin-nav-section">{{ t.menu or 'Menu' }}</div>
            <a href="#dashboard" class="admin-nav-link active" data-section="dashboard">
                <span class="mi">dashboard</span>
                {{ t.dashboard or 'Dashboard' }}
            </a>
            <a href="#users" class="admin-nav-link" data-section="users">
                <span class="mi">group</span>
                {{ t.users or 'Users' }}
            </a>
            <a href="#projects" class="admin-nav-link" data-section="projects">
                <span class="mi">folder</span>
                {{ t.projects or 'Projects' }}
            </a>
            <a href="#styles" class="admin-nav-link" data-section="styles">
                <span class="mi">palette</span>
                {{ t.styles or 'Styles' }}
            </a>
            <a href="#templates" class="admin-nav-link" data-section="templates">
                <span class="mi">description</span>
                {{ t.templates or 'Templates' }}
            </a>
            <a href="#settings" class="admin-nav-link d-none" data-section="settings">
                <span class="mi">tune</span>
                {{ t.settings or 'Settings' }}
            </a>
            <a href="#presentation" class="admin-nav-link" data-section="presentation">
                <span class="mi">tune</span>
                {{ t.customization or 'Customization' }}
            </a>
            <a href="#maintenance" class="admin-nav-link" data-section="maintenance">
                <span class="mi">engineering</span>
                {{ t.maintenance or 'Maintenance' }}
            </a>
            <div class="admin-nav-divider"></div>
            <div class="admin-nav-section">{{ t.navigation or 'Navigation' }}</div>
            <a href="{{ basePath }}/workarea" class="admin-nav-link">
                <span class="mi">arrow_back</span>
                {{ t.back_to_workarea or 'Back to Workarea' }}
            </a>
            <a href="{{ basePath }}/logout" class="admin-nav-link">
                <span class="mi">logout</span>
                {{ t.logout or 'Logout' }}
            </a>
        </div>
    </nav>

    <!-- Main content -->
    <main class="admin-main">
        <!-- Header -->
        <header class="admin-header">
            <div class="d-flex align-items-center gap-3">
                <button class="btn-admin-outline d-lg-none" id="sidebarToggle">
                    <span class="mi">menu</span>
                </button>
                <h1 class="admin-header-title" id="sectionTitle">{{ t.dashboard or 'Dashboard' }}</h1>
            </div>
            <div class="admin-header-user">
                <span class="d-none d-md-inline" style="font-weight: 500;">{{ user.email }}</span>
                <div class="user-avatar">{{ user.usernameFirsLetter or 'A' }}</div>
            </div>
        </header>

        <!-- Content -->
        <div class="admin-content">
            {% if adminSettings.maintenance.maintenance_mode %}
            <div class="maintenance-banner" id="maintenanceBanner">
                <span class="mi mi-sm">engineering</span>
                <strong>{{ t.maintenance_mode_active or 'Maintenance mode is active' }}</strong> &mdash;
                {{ t.maintenance_mode_active_desc or 'Non-administrator users cannot access the platform.' }}
            </div>
            {% endif %}
            <!-- Dashboard Section -->
            <section id="dashboard" class="admin-section active">
                <div class="stats-grid">
                    <div class="stats-card">
                        <div class="stats-icon primary">
                            <span class="mi">group</span>
                        </div>
                        <div class="stats-content">
                            <div class="stats-value" id="stat-totalUsers">-</div>
                            <div class="stats-label">{{ t.total_users or 'Total Users' }}</div>
                        </div>
                    </div>
                    <div class="stats-card">
                        <div class="stats-icon success">
                            <span class="mi">person_check</span>
                        </div>
                        <div class="stats-content">
                            <div class="stats-value" id="stat-activeUsers">-</div>
                            <div class="stats-label">{{ t.active_users or 'Active Users' }}</div>
                        </div>
                    </div>
                    <div class="stats-card">
                        <div class="stats-icon info">
                            <span class="mi">folder</span>
                        </div>
                        <div class="stats-content">
                            <div class="stats-value" id="stat-totalProjects">-</div>
                            <div class="stats-label">{{ t.total_projects or 'Total Projects' }}</div>
                        </div>
                    </div>
                    <div class="stats-card">
                        <div class="stats-icon warning">
                            <span class="mi">edit_note</span>
                        </div>
                        <div class="stats-content">
                            <div class="stats-value" id="stat-activeProjects">-</div>
                            <div class="stats-label">{{ t.active_projects or 'Active Projects' }}</div>
                        </div>
                    </div>
                </div>

                <div class="admin-card">
                    <div class="admin-card-header">
                        <h5>
                            <span class="mi mi-sm">info</span>
                            {{ t.system_info or 'System Info' }}
                        </h5>
                    </div>
                    <div class="admin-card-body" id="system-info-content">
                        <div class="system-info-loading">
                            <span class="mi">hourglass_empty</span>
                            &nbsp;{{ t.loading or 'Loading' }}...
                        </div>
                    </div>
                </div>
            </section>

            <!-- Users Section -->
            <section id="users" class="admin-section">
                <div class="admin-card">
                    <div class="admin-card-header">
                        <h5>
                            <span class="mi mi-sm">group</span>
                            {{ t.user_management or 'User Management' }}
                        </h5>
                        <div class="d-flex gap-2 align-items-center">
                            <div style="position: relative;">
                                <span class="mi mi-sm" style="position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: var(--admin-text-muted);">search</span>
                                <input type="search" class="admin-input" id="userSearch" placeholder="{{ t.search or 'Search' }}..." style="width: 200px; padding-left: 36px;">
                            </div>
                            <button class="btn-admin-primary" data-bs-toggle="modal" data-bs-target="#createUserModal">
                                <span class="mi mi-sm">person_add</span>
                                {{ t.create_user or 'Create User' }}
                            </button>
                        </div>
                    </div>
                    <div class="loading-overlay" id="usersLoading">
                        <div class="spinner"></div>
                        <p style="color: var(--admin-text-muted);">{{ t.loading or 'Loading' }}...</p>
                    </div>
                    <div class="bulk-actions-bar" id="bulkActionsBar">
                        <span class="selected-count" id="selectedCount">0 {{ t.selected or 'selected' }}</span>
                        <button class="btn-admin-primary btn-admin-danger" id="bulkDeleteBtn">
                            <span class="mi mi-sm">delete</span>
                            {{ t.delete_selected or 'Delete Selected' }}
                        </button>
                        <button class="btn-admin-outline" id="clearSelectionBtn">
                            <span class="mi mi-sm">close</span>
                            {{ t.clear_selection or 'Clear' }}
                        </button>
                    </div>
                    <div class="admin-table-wrapper" style="max-height: 60vh; overflow-y: auto;">
                        <table class="admin-table" id="usersTable">
                            <thead style="position: sticky; top: 0; z-index: 10;">
                                <tr>
                                    <th style="width: 40px;">
                                        <input type="checkbox" class="bulk-checkbox" id="selectAllUsers" title="{{ t.select_all or 'Select All' }}">
                                    </th>
                                    <th class="sortable" data-sort="id">
                                        ID <span class="mi mi-sm sort-icon">unfold_more</span>
                                    </th>
                                    <th class="sortable" data-sort="email">
                                        {{ t.user or 'User' }} <span class="mi mi-sm sort-icon">unfold_more</span>
                                    </th>
                                    <th>{{ t.roles or 'Roles' }}</th>
                                    <th>{{ t.quota_mb or 'Quota (MB)' }}</th>
                                    <th>{{ t.status or 'Status' }}</th>
                                    <th style="width: 150px;">{{ t.actions or 'Actions' }}</th>
                                </tr>
                            </thead>
                            <tbody id="usersTableBody">
                            </tbody>
                        </table>
                    </div>
                    <div class="pagination-wrapper">
                        <span class="pagination-info" id="usersPagination">-</span>
                        <div class="pagination-btns">
                            <button class="btn-admin-outline" id="usersPrevBtn" disabled>
                                <span class="mi mi-sm">chevron_left</span>
                            </button>
                            <button class="btn-admin-outline" id="usersNextBtn" disabled>
                                <span class="mi mi-sm">chevron_right</span>
                            </button>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Projects Section -->
            <section id="projects" class="admin-section">
                <div class="admin-card">
                    <div class="admin-card-header">
                        <h5>
                            <span class="mi mi-sm">folder</span>
                            {{ t.project_management or 'Project Management' }}
                        </h5>
                        <div class="admin-filter-group">
                            <input type="search" class="admin-input" id="projectOwnerFilter" placeholder="{{ t.owner or 'Owner' }}" style="width: 200px;">
                            <input type="search" class="admin-input" id="projectTitleFilter" placeholder="{{ t.title or 'Title' }}" style="width: 200px;">
                            <select class="admin-input" id="projectStatusFilter">
                                <option value="">{{ t.all_statuses or 'All statuses' }}</option>
                                <option value="active">active</option>
                                <option value="inactive">inactive</option>
                                <option value="archived">archived</option>
                            </select>
                            <select class="admin-input" id="projectVisibilityFilter">
                                <option value="">{{ t.all_visibility or 'All visibility' }}</option>
                                <option value="public">public</option>
                                <option value="private">private</option>
                            </select>
                        </div>
                    </div>
                    <div class="loading-overlay" id="projectsLoading">
                        <div class="spinner"></div>
                        <p style="color: var(--admin-text-muted);">{{ t.loading or 'Loading' }}...</p>
                    </div>
                    <div class="bulk-actions-bar" id="projectsBulkActionsBar">
                        <span class="selected-count" id="projectsSelectedCount">0 {{ t.selected or 'selected' }}</span>
                        <button class="btn-admin-outline" id="projectsBulkActivateBtn">
                            <span class="mi mi-sm">toggle_on</span>
                            {{ t.activate or 'Activate' }}
                        </button>
                        <button class="btn-admin-outline" id="projectsBulkDeactivateBtn">
                            <span class="mi mi-sm">toggle_off</span>
                            {{ t.deactivate or 'Deactivate' }}
                        </button>
                        <button class="btn-admin-outline" id="projectsBulkArchiveBtn">
                            <span class="mi mi-sm">archive</span>
                            {{ t.archive or 'Archive' }}
                        </button>
                        <button class="btn-admin-primary btn-admin-danger" id="projectsBulkDeleteBtn">
                            <span class="mi mi-sm">delete</span>
                            {{ t.delete_selected or 'Delete Selected' }}
                        </button>
                        <button class="btn-admin-outline" id="projectsClearSelectionBtn">
                            <span class="mi mi-sm">close</span>
                            {{ t.clear_selection or 'Clear' }}
                        </button>
                    </div>
                    <div class="admin-table-wrapper" style="max-height: 60vh; overflow-y: auto;">
                        <table class="admin-table" id="projectsTable">
                            <thead style="position: sticky; top: 0; z-index: 10;">
                                <tr>
                                    <th style="width: 40px;">
                                        <input type="checkbox" class="bulk-checkbox" id="selectAllProjects" title="{{ t.select_all or 'Select All' }}">
                                    </th>
                                    <th class="sortable" data-sort-project="id">
                                        ID <span class="mi mi-sm sort-icon">unfold_more</span>
                                    </th>
                                    <th class="sortable" data-sort-project="title">
                                        {{ t.title or 'Title' }} <span class="mi mi-sm sort-icon">unfold_more</span>
                                    </th>
                                    <th>{{ t.owner or 'Owner' }}</th>
                                    <th>{{ t.status or 'Status' }}</th>
                                    <th>{{ t.visibility or 'Visibility' }}</th>
                                    <th>{{ t.created or 'Created' }}</th>
                                    <th style="width: 100px;">{{ t.actions or 'Actions' }}</th>
                                </tr>
                            </thead>
                            <tbody id="projectsTableBody">
                            </tbody>
                        </table>
                    </div>
                    <div class="pagination-wrapper">
                        <span class="pagination-info" id="projectsPagination">-</span>
                        <div class="pagination-btns">
                            <button class="btn-admin-outline" id="projectsPrevBtn" disabled>
                                <span class="mi mi-sm">chevron_left</span>
                            </button>
                            <button class="btn-admin-outline" id="projectsNextBtn" disabled>
                                <span class="mi mi-sm">chevron_right</span>
                            </button>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Styles Section -->
            <section id="styles" class="admin-section">
                <div class="admin-card">
                    <div class="admin-card-header">
                        <h5>
                            <span class="mi mi-sm">palette</span>
                            {{ t.themes_management or 'Themes Management' }}
                        </h5>
                    </div>
                    <div class="admin-card-body">
                        <div class="ext-toolbar">
                            <button id="uploadThemeBtn" class="btn-admin-primary">
                                <span class="mi mi-sm">upload</span>
                                {{ t.upload_theme or 'Upload Theme' }}
                            </button>
                            <input type="file" id="themeFileInput" accept=".zip" style="display: none;">
                        </div>
                        <div id="themesTableContainer">
                            <table class="admin-table">
                                <thead>
                                    <tr>
                                        <th style="width: 60px;">{{ t.preview or 'Preview' }}</th>
                                        <th>{{ t.name or 'Name' }}</th>
                                        <th style="width: 80px;">{{ t.source or 'Source' }}</th>
                                        <th>{{ t.version or 'Version' }}</th>
                                        <th>{{ t.author or 'Author' }}</th>
                                        <th style="width: 80px;">{{ t.enabled or 'Enabled' }}</th>
                                        <th style="width: 80px;">{{ t.default or 'Default' }}</th>
                                        <th style="width: 100px;">{{ t.actions or 'Actions' }}</th>
                                    </tr>
                                </thead>
                                <tbody id="themesTableBody">
                                    <tr>
                                        <td colspan="8" class="text-center">
                                            <span class="mi mi-spin">sync</span>
                                            {{ t.loading or 'Loading...' }}
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Templates Section -->
            <section id="templates" class="admin-section">
                <div class="admin-card">
                    <div class="admin-card-header">
                        <h5>
                            <span class="mi mi-sm">description</span>
                            {{ t.templates_management or 'Templates Management' }}
                        </h5>
                    </div>
                    <div class="admin-card-body">
                        <div class="ext-toolbar">
                            <div class="ext-toolbar-left">
                                <label for="templateLocaleSelect">{{ t.locale or 'Locale' }}:</label>
                                <select id="templateLocaleSelect" class="admin-input" style="width: auto; min-width: 120px;">
                                    <option value="es">Español (es)</option>
                                    <option value="en">English (en)</option>
                                    <option value="fr">Français (fr)</option>
                                    <option value="de">Deutsch (de)</option>
                                    <option value="it">Italiano (it)</option>
                                    <option value="pt">Português (pt)</option>
                                    <option value="ca">Català (ca)</option>
                                    <option value="eu">Euskara (eu)</option>
                                    <option value="gl">Galego (gl)</option>
                                    <option value="va">Valencià (va)</option>
                                    <option value="eo">Esperanto (eo)</option>
                                    <option value="nl">Nederlands (nl)</option>
                                    <option value="pl">Polski (pl)</option>
                                    <option value="ru">Русский (ru)</option>
                                    <option value="zh">中文 (zh)</option>
                                    <option value="ja">日本語 (ja)</option>
                                    <option value="ko">한국어 (ko)</option>
                                    <option value="ar">العربية (ar)</option>
                                </select>
                            </div>
                            <button id="uploadTemplateBtn" class="btn-admin-primary">
                                <span class="mi mi-sm">upload</span>
                                {{ t.upload_template or 'Upload Template' }}
                            </button>
                            <input type="file" id="templateFileInput" accept=".elpx" style="display: none;">
                        </div>
                        <div id="templatesTableContainer">
                            <table class="admin-table">
                                <thead>
                                    <tr>
                                        <th>{{ t.filename or 'Filename' }}</th>
                                        <th>{{ t.display_name or 'Display Name' }}</th>
                                        <th>{{ t.description or 'Description' }}</th>
                                        <th style="width: 80px;">{{ t.enabled or 'Enabled' }}</th>
                                        <th style="width: 120px;">{{ t.actions or 'Actions' }}</th>
                                    </tr>
                                </thead>
                                <tbody id="templatesTableBody">
                                    <tr>
                                        <td colspan="5" class="text-center">
                                            <span class="mi mi-spin">sync</span>
                                            {{ t.loading or 'Loading...' }}
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Settings Section -->
            <section id="settings" class="admin-section">
                <div class="admin-card">
                    <div class="admin-card-header">
                        <h5>
                            <span class="mi mi-sm">settings</span>
                            {{ t.global_settings or 'Global Settings' }}
                        </h5>
                    </div>
                    <div class="admin-card-body">
                        <div class="admin-settings-actions">
                            <button id="settingsSaveBtn" class="btn-admin-primary">
                                <span class="mi mi-sm">save</span>
                                {{ t.save or 'Save' }}
                            </button>
                            <span id="settingsSaveStatus" class="admin-settings-status"></span>
                        </div>
                        <div class="admin-settings-group">
                            <h6>{{ t.maintenance or 'Maintenance' }}</h6>
                            <div class="admin-settings-grid">
                                <div class="admin-field">
                                    <label>MAINTENANCE_MODE</label>
                                    <div class="form-check-custom">
                                        <input type="checkbox" data-setting-key="MAINTENANCE_MODE" data-setting-type="boolean" {% if adminSettings.maintenance.maintenance_mode %}checked{% endif %}>
                                        <span>{{ t.active or 'Active' }}</span>
                                    </div>
                                    <small>{{ t.maintenance_mode_desc or 'When enabled, non-administrator users will see a maintenance page. Administrators retain full access.' }}</small>
                                </div>
                            </div>
                        </div>
                        <div class="admin-settings-group">
                            <h6>{{ t.platform_and_collaboration or 'Platform and collaboration' }}</h6>
                            <div class="admin-settings-grid">
                                <div class="admin-field">
                                    <label>ONLINE_THEMES_INSTALL</label>
                                    <div class="form-check-custom">
                                        <input type="checkbox" data-setting-key="ONLINE_THEMES_INSTALL" data-setting-type="boolean" {% if adminSettings.general.online_themes_install %}checked{% endif %}>
                                        <span>{{ t.active or 'Active' }}</span>
                                    </div>
                                    <small>{{ t.allows_install_themes_online or 'Allows installing themes online.' }}</small>
                                </div>
                                <div class="admin-field">
                                    <label>ONLINE_IDEVICES_INSTALL</label>
                                    <div class="form-check-custom">
                                        <input type="checkbox" data-setting-key="ONLINE_IDEVICES_INSTALL" data-setting-type="boolean" {% if adminSettings.general.online_idevices_install %}checked{% endif %}>
                                        <span>{{ t.active or 'Active' }}</span>
                                    </div>
