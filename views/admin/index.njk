        }

        async function impersonateUser(userId, userEmail) {
            const confirmText = T.confirm_impersonate.replace('{email}', userEmail || `#${userId}`);
            if (!confirm(confirmText)) return;

            try {
                const res = await fetch(`${API_BASE}/impersonation/start`, {
                    method: 'POST',
                    credentials: 'include',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ user_id: userId })
                });

                const data = await res.json().catch(() => ({}));
                if (!res.ok) {
                    throw new Error(data.message || T.impersonation_failed);
                }

                const redirectPath = data.redirect_to || '/workarea';
                window.location.href = `${BASE_PATH}${redirectPath}`;
            } catch (err) {
                console.error('Failed to start impersonation:', err);
                alert(err.message || T.impersonation_failed);
            }
        }

        async function downloadProjectElpx(projectId, projectTitle) {
            try {
                const res = await fetch(`${API_BASE}/projects/${projectId}/download`, { credentials: 'include' });
                if (!res.ok) {
                    const err = await res.json().catch(() => ({}));
                    alert(err.message || T.error_downloading || 'Download failed');
                    return;
                }
                const blob = await res.blob();
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = res.headers.get('content-disposition')?.match(/filename="([^"]+)"/)?.[1] || `project-${projectId}.elpx`;
                a.click();
                URL.revokeObjectURL(url);
            } catch (err) {
                console.error('Download failed:', err);
            }
        }

        // Edit user
        async function editUser(userId) {
            try {
                const res = await fetch(`${API_BASE}/users/${userId}`, { credentials: 'include' });
                if (!res.ok) throw new Error('Failed to load user');
                const data = await res.json();
                const user = data.user;

                const form = document.getElementById('editUserForm');
                form.querySelector('[name="userId"]').value = user.id;
                form.querySelector('[name="email"]').value = user.email;
                document.getElementById('editRoleAdmin').checked = user.roles.includes('ROLE_ADMIN');
                document.getElementById('editRoleEditor').checked = user.roles.includes('ROLE_EDITOR');
                document.getElementById('editUserQuota').value = user.quota_mb != null ? user.quota_mb : '';
                document.getElementById('editUserActive').checked = user.is_active === 1;
                document.getElementById('editUserStatusLabel').textContent = user.is_active === 1 ? T.active : T.inactive;

                new bootstrap.Modal(document.getElementById('editUserModal')).show();
            } catch (err) {
                console.error('Failed to load user:', err);
                alert('Failed to load user');
            }
        }

        // Update status label
        document.getElementById('editUserActive').addEventListener('change', (e) => {
            document.getElementById('editUserStatusLabel').textContent = e.target.checked ? T.active : T.inactive;
        });

        // Save user
        document.getElementById('editUserForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const form = e.target;
            const userId = form.querySelector('[name="userId"]').value;

            const roles = ['ROLE_USER'];
            if (document.getElementById('editRoleAdmin').checked) roles.push('ROLE_ADMIN');
            if (document.getElementById('editRoleEditor').checked) roles.push('ROLE_EDITOR');

            const isActive = document.getElementById('editUserActive').checked;
            const quotaValue = document.getElementById('editUserQuota').value;
            const quota_mb = quotaValue === '' ? null : parseInt(quotaValue, 10);

            try {
                // Update roles
                let res = await fetch(`${API_BASE}/users/${userId}/roles`, {
                    method: 'PATCH',
                    credentials: 'include',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ roles })
                });

                if (!res.ok) {
                    const data = await res.json();
                    throw new Error(data.message || 'Failed to update roles');
                }

                // Update status
                res = await fetch(`${API_BASE}/users/${userId}/status`, {
                    method: 'PATCH',
                    credentials: 'include',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ is_active: isActive })
                });

                if (!res.ok) {
                    const data = await res.json();
                    throw new Error(data.message || 'Failed to update status');
                }

                // Update quota
                res = await fetch(`${API_BASE}/users/${userId}/quota`, {
                    method: 'PATCH',
                    credentials: 'include',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ quota_mb })
                });

                if (!res.ok) {
                    const data = await res.json();
                    throw new Error(data.message || 'Failed to update quota');
                }

                bootstrap.Modal.getInstance(document.getElementById('editUserModal')).hide();
                loadUsers();
            } catch (err) {
                console.error('Failed to save user:', err);
                alert(err.message || 'Failed to save user');
            }
        });

        // Delete user
        document.getElementById('deleteUserBtn').addEventListener('click', async () => {
            if (!confirm(T.confirm_delete)) return;

            const userId = document.getElementById('editUserForm').querySelector('[name="userId"]').value;

            try {
                const res = await fetch(`${API_BASE}/users/${userId}`, {
                    method: 'DELETE',
                    credentials: 'include'
                });

                if (!res.ok) {
                    const data = await res.json();
                    throw new Error(data.message || 'Failed to delete user');
                }

                bootstrap.Modal.getInstance(document.getElementById('editUserModal')).hide();
                loadUsers();
            } catch (err) {
                console.error('Failed to delete user:', err);
                alert(err.message || 'Failed to delete user');
            }
        });

        // Create user
        document.getElementById('createUserForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const form = e.target;

            const roles = ['ROLE_USER'];
            form.querySelectorAll('[name="roles"]:checked:not(:disabled)').forEach(cb => {
                roles.push(cb.value);
            });

            const quotaValue = form.querySelector('[name="quota_mb"]').value;
            const quota_mb = quotaValue === '' ? null : parseInt(quotaValue, 10);

            try {
                const res = await fetch(`${API_BASE}/users`, {
                    method: 'POST',
                    credentials: 'include',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        email: form.querySelector('[name="email"]').value,
                        password: form.querySelector('[name="password"]').value,
                        roles,
                        quota_mb
                    })
                });

                if (!res.ok) {
                    const data = await res.json();
                    throw new Error(data.message || 'Failed to create user');
                }

                bootstrap.Modal.getInstance(document.getElementById('createUserModal')).hide();
                form.reset();
                navigateTo('users');
            } catch (err) {
                console.error('Failed to create user:', err);
                alert(err.message || 'Failed to create user');
            }
        });

        // Sidebar toggle (mobile)
        document.getElementById('sidebarToggle')?.addEventListener('click', () => {
            document.getElementById('adminSidebar').classList.toggle('show');
            document.getElementById('sidebarOverlay').classList.toggle('show');
        });

        document.getElementById('sidebarOverlay')?.addEventListener('click', () => {
            document.getElementById('adminSidebar').classList.remove('show');
            document.getElementById('sidebarOverlay').classList.remove('show');
        });

        // ==========================================
        // Admin Themes Management
        // ==========================================

        async function loadAdminThemes() {
            const tbody = document.getElementById('themesTableBody');
            try {
                const response = await fetch('/api/admin/themes', { credentials: 'include' });
                if (!response.ok) throw new Error('Failed to load themes');

                const data = await response.json();

                if (!data.themes || data.themes.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="8" class="text-center">{{ t.no_themes or 'No themes available.' }}</td></tr>`;
                    return;
                }

                tbody.innerHTML = data.themes.map(theme => {
                    // Determine screenshot path based on source
                    // 'base' = builtin themes from public/files/perm/themes/base/
                    // 'site' = admin-uploaded themes from FILES_DIR/themes/site/
                    const screenshotPath = theme.source === 'base'
                        ? BASE_PATH + '/files/perm/themes/base/' + theme.dirName + '/screenshot.png'
                        : (theme.storagePath ? BASE_PATH + '/site-files/themes/' + theme.dirName + '/screenshot.png' : '');

                    // Source badge - different colors for base vs site themes
                    const sourceBadge = theme.source === 'base'
                        ? '<span class="badge badge-primary">' + T.base + '</span>'
                        : '<span class="badge badge-secondary">' + T.site + '</span>';

                    // Toggle for base vs site themes (both can be toggled now)
                    const toggleHtml = theme.source === 'base'
                        ? `<label class="toggle-switch" ${theme.isDefault ? 'title="{{ t.cannot_disable_default or "Cannot disable the default theme" }}"' : ''}>
                               <input type="checkbox" ${theme.isEnabled ? 'checked' : ''} ${theme.isDefault ? 'disabled' : ''} onchange="toggleBuiltinThemeEnabled('${theme.dirName}', this.checked)">
                               <span class="toggle-slider"></span>
                           </label>`
                        : `<label class="toggle-switch" ${theme.isDefault ? 'title="{{ t.cannot_disable_default or "Cannot disable the default theme" }}"' : ''}>
                               <input type="checkbox" ${theme.isEnabled ? 'checked' : ''} ${theme.isDefault ? 'disabled' : ''} onchange="toggleThemeEnabled(${theme.id}, this.checked)">
                               <span class="toggle-slider"></span>
                           </label>`;

                    // Set default button for both base and site themes
                    let defaultHtml;
                    if (theme.isDefault) {
                        defaultHtml = '<span class="badge badge-success">{{ t.default or "Default" }}</span>';
                    } else if (theme.source === 'base') {
                        defaultHtml = `<button class="btn-admin-sm" onclick="setDefaultBuiltinTheme('${theme.dirName}')" ${!theme.isEnabled ? 'disabled' : ''}>{{ t.set_default or "Set" }}</button>`;
                    } else {
                        defaultHtml = `<button class="btn-admin-sm" onclick="setDefaultTheme(${theme.id})" ${!theme.isEnabled ? 'disabled' : ''}>{{ t.set_default or "Set" }}</button>`;
                    }

                    // Delete button only for site themes (base themes cannot be deleted)
                    const deleteHtml = theme.source === 'base'
                        ? ''
                        : `<button class="btn-admin-sm btn-danger" onclick="deleteTheme(${theme.id}, '${escapeHtml(theme.displayName)}')">
                               <span class="mi mi-sm">delete</span>
                           </button>`;

                    // Add class for base themes to style them differently
                    const rowClass = theme.source === 'base' ? 'theme-row-base' : 'theme-row-site';

                    return `
                    <tr data-theme-id="${theme.id || theme.dirName}" class="${rowClass}">
                        <td><img src="${screenshotPath}" alt="" style="width: 50px; height: 40px; object-fit: cover; border-radius: 4px;" onerror="this.style.display='none'"></td>
                        <td><strong>${escapeHtml(theme.displayName)}</strong><br><small class="text-muted">${escapeHtml(theme.dirName)}</small></td>
                        <td>${sourceBadge}</td>
                        <td>${escapeHtml(theme.version || '-')}</td>
                        <td>${escapeHtml(theme.author || '-')}</td>
                        <td>${toggleHtml}</td>
                        <td>${defaultHtml}</td>
                        <td>${deleteHtml}</td>
                    </tr>
                `}).join('');
            } catch (error) {
                console.error('Error loading themes:', error);
                tbody.innerHTML = `<tr><td colspan="8" class="text-center text-danger">{{ t.error_loading or 'Error loading data' }}</td></tr>`;
            }
        }

        async function uploadTheme(file) {
            const formData = new FormData();
            formData.append('file', file);

            try {
                const response = await fetch('/api/admin/themes/upload', {
                    method: 'POST',
                    body: formData,
                    credentials: 'include'
                });

                const result = await response.json();
                if (!response.ok) {
                    throw new Error(result.message || 'Upload failed');
                }

                showNotification('{{ t.theme_uploaded or "Theme uploaded successfully" }}', 'success');
                loadAdminThemes();
            } catch (error) {
                showNotification(error.message, 'error');
            }
        }

        async function toggleThemeEnabled(id, enabled) {
            try {
                const response = await fetch(`/api/admin/themes/${id}/enabled`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ isEnabled: enabled }),
                    credentials: 'include'
                });

                if (!response.ok) throw new Error('Failed to update');
                loadAdminThemes();
            } catch (error) {
                showNotification(error.message, 'error');
                loadAdminThemes(); // Reload to reset checkbox state
            }
        }

        async function setDefaultTheme(id) {
            try {
                const response = await fetch(`/api/admin/themes/${id}/default`, {
                    method: 'PATCH',
                    credentials: 'include'
                });

                if (!response.ok) {
                    const result = await response.json();
                    throw new Error(result.message || 'Failed to set default');
                }

                showNotification('{{ t.default_theme_set or "Default theme set" }}', 'success');
                loadAdminThemes();
            } catch (error) {
                showNotification(error.message, 'error');
            }
        }

        async function toggleBuiltinThemeEnabled(dirName, isEnabled) {
            try {
                const response = await fetch(`/api/admin/themes/builtin/${encodeURIComponent(dirName)}/enabled`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({ isEnabled })
                });

                if (!response.ok) {
                    const result = await response.json();
                    throw new Error(result.message || 'Failed to update');
                }

                loadAdminThemes();
            } catch (error) {
                showNotification(error.message, 'error');
                loadAdminThemes(); // Reload to reset checkbox state
            }
        }

        async function setDefaultBuiltinTheme(dirName) {
            try {
                const response = await fetch(`/api/admin/themes/builtin/${encodeURIComponent(dirName)}/default`, {
                    method: 'PATCH',
                    credentials: 'include'
                });

                if (!response.ok) {
                    const result = await response.json();
                    throw new Error(result.message || 'Failed to set default');
                }

                showNotification('{{ t.default_theme_set or "Default theme set" }}', 'success');
                loadAdminThemes();
            } catch (error) {
                showNotification(error.message, 'error');
            }
        }

        async function deleteTheme(id, name) {
            if (!confirm(`{{ t.confirm_delete_theme or "Are you sure you want to delete the theme" }} "${name}"?`)) {
                return;
            }

            try {
                const response = await fetch(`/api/admin/themes/${id}`, {
                    method: 'DELETE',
                    credentials: 'include'
                });

                if (!response.ok) throw new Error('Failed to delete');

                showNotification('{{ t.theme_deleted or "Theme deleted" }}', 'success');
                loadAdminThemes();
            } catch (error) {
                showNotification(error.message, 'error');
            }
        }

        // Theme upload button handlers
        document.getElementById('uploadThemeBtn')?.addEventListener('click', () => {
            document.getElementById('themeFileInput').click();
        });

        document.getElementById('themeFileInput')?.addEventListener('change', (e) => {
            const file = e.target.files[0];
            if (file) {
                uploadTheme(file);
                e.target.value = ''; // Reset input
            }
        });

        // ==========================================
        // Admin Templates Management
        // ==========================================

        let currentTemplateLocale = 'es';

        async function loadAdminTemplates() {
            const tbody = document.getElementById('templatesTableBody');
            try {
                const response = await fetch(`/api/admin/templates?locale=${currentTemplateLocale}`, { credentials: 'include' });
                if (!response.ok) throw new Error('Failed to load templates');

                const data = await response.json();

                if (!data.templates || data.templates.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="5" class="text-center">{{ t.no_templates or 'No templates for this locale.' }}</td></tr>`;
                    return;
                }

                tbody.innerHTML = data.templates.map(template => `
                    <tr data-template-id="${template.id}">
                        <td><code>${escapeHtml(template.filename)}</code></td>
                        <td>${escapeHtml(template.displayName)}</td>
                        <td>${escapeHtml(template.description || '-')}</td>
                        <td>
                            <label class="toggle-switch">
                                <input type="checkbox" ${template.isEnabled ? 'checked' : ''} onchange="toggleTemplateEnabled(${template.id}, this.checked)">
                                <span class="toggle-slider"></span>
                            </label>
                        </td>
                        <td>
                            <a href="/api/admin/templates/${template.id}/download" class="btn-admin-sm" title="{{ t.download or 'Download' }}">
                                <span class="mi mi-sm">download</span>
                            </a>
                            <button class="btn-admin-sm btn-danger" onclick="deleteTemplate(${template.id}, '${escapeHtml(template.displayName)}')">
                                <span class="mi mi-sm">delete</span>
                            </button>
                        </td>
                    </tr>
                `).join('');
            } catch (error) {
                console.error('Error loading templates:', error);
                tbody.innerHTML = `<tr><td colspan="5" class="text-center text-danger">{{ t.error_loading or 'Error loading data' }}</td></tr>`;
            }
        }

        async function uploadTemplate(file) {
            const formData = new FormData();
            formData.append('file', file);
            formData.append('locale', currentTemplateLocale);

            try {
                const response = await fetch('/api/admin/templates/upload', {
                    method: 'POST',
                    body: formData,
                    credentials: 'include'
                });

                const result = await response.json();
                if (!response.ok) {
                    throw new Error(result.message || 'Upload failed');
                }

                showNotification('{{ t.template_uploaded or "Template uploaded successfully" }}', 'success');
                loadAdminTemplates();
            } catch (error) {
                showNotification(error.message, 'error');
            }
        }

        async function toggleTemplateEnabled(id, enabled) {
            try {
                const response = await fetch(`/api/admin/templates/${id}/enabled`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ isEnabled: enabled }),
                    credentials: 'include'
                });

                if (!response.ok) throw new Error('Failed to update');
                loadAdminTemplates();
            } catch (error) {
                showNotification(error.message, 'error');
                loadAdminTemplates();
            }
        }

        async function deleteTemplate(id, name) {
            if (!confirm(`{{ t.confirm_delete_template or "Are you sure you want to delete the template" }} "${name}"?`)) {
                return;
            }

            try {
                const response = await fetch(`/api/admin/templates/${id}`, {
                    method: 'DELETE',
                    credentials: 'include'
                });

                if (!response.ok) throw new Error('Failed to delete');

                showNotification('{{ t.template_deleted or "Template deleted" }}', 'success');
                loadAdminTemplates();
            } catch (error) {
                showNotification(error.message, 'error');
            }
        }

        // Template locale selector
        document.getElementById('templateLocaleSelect')?.addEventListener('change', (e) => {
            currentTemplateLocale = e.target.value;
            loadAdminTemplates();
        });

        // Template upload button handlers
        document.getElementById('uploadTemplateBtn')?.addEventListener('click', () => {
            document.getElementById('templateFileInput').click();
        });

        document.getElementById('templateFileInput')?.addEventListener('change', (e) => {
            const file = e.target.files[0];
            if (file) {
                uploadTemplate(file);
                e.target.value = '';
            }
        });

        // Utility function for escaping HTML
        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // Notification helper
        function showNotification(message, type = 'info') {
            // Simple notification - can be enhanced with a toast library
            alert(message);
        }

        // Load themes when Styles section is shown
        document.querySelector('.admin-nav-link[data-section="styles"]')?.addEventListener('click', () => {
            setTimeout(() => loadAdminThemes(), 100);
        });

        // Load templates when Templates section is shown
        document.querySelector('.admin-nav-link[data-section="templates"]')?.addEventListener('click', () => {
            setTimeout(() => loadAdminTemplates(), 100);
        });

        // Initial load
        loadStats();
        loadSystemInfo();
    </script>
</body>
</html>
