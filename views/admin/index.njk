        async function updateProjectsBulkStatus(status, buttonId, loadingText) {
            const count = selectedProjectIds.size;
            if (count === 0) return;

            const btn = document.getElementById(buttonId);
            const originalText = btn.innerHTML;
            btn.innerHTML = `<span class="mi mi-sm">hourglass_empty</span> ${loadingText}`;
            btn.disabled = true;

            let updated = 0;
            let errors = [];

            for (const projectId of selectedProjectIds) {
                try {
                    const res = await fetch(`${API_BASE}/projects/${projectId}/status`, {
                        method: 'PATCH',
                        credentials: 'include',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ status })
                    });

                    if (res.ok) {
                        updated++;
                    } else {
                        const data = await res.json();
                        errors.push(`Project ${projectId}: ${data.message || 'Failed'}`);
