<div class="modal exe-modal-fade" tabindex="-1" id="modalImageOptimizer" role="dialog" aria-hidden="true" data-testid="modal-image-optimizer" data-open="false">
    <div class="modal-dialog modal-dialog-centered modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <div class="modal-title">{{ 'Image Optimizer' | trans }}</div>
                <button type="button" class="close image-optimizer-close-btn" data-dismiss="modal" aria-label="{{ 'Close' | trans }}">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div id="imageOptimizerBody" class="modal-body">
                <!-- Loading state -->
                <div class="image-optimizer-loading text-center py-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">{{ 'Loading...' | trans }}</span>
                    </div>
                    <p class="mt-2 text-muted">{{ 'Loading project images...' | trans }}</p>
                </div>

                <!-- Empty state (shown when no images) -->
                <div class="image-optimizer-empty text-center py-4 d-none">
                    <p class="text-muted">{{ 'No PNG or JPEG images found in this project.' | trans }}</p>
                </div>

                <!-- Main content (hidden until loaded) -->
                <div class="image-optimizer-content d-none">
                    <!-- Settings panel (compact row) -->
                    <div class="image-optimizer-settings d-flex align-items-center gap-3 mb-3 flex-wrap">
                        <div class="d-flex align-items-center gap-2">
                            <label class="mb-0 fw-semibold">{{ 'Preset' | trans }}:</label>
                            <select class="form-select form-select-sm image-optimizer-preset" style="width: auto;">
                                <option value="light">{{ 'Light' | trans }}</option>
                                <option value="medium" selected>{{ 'Medium' | trans }}</option>
                                <option value="strong">{{ 'Strong' | trans }}</option>
                            </select>
                        </div>
                        <div class="image-optimizer-quality-container d-flex align-items-center gap-2 d-none">
                            <label class="mb-0">{{ 'JPEG Quality' | trans }}:</label>
                            <input type="range" class="form-range image-optimizer-quality" style="width: 100px;" min="50" max="100" value="85">
                            <span class="image-optimizer-quality-value badge bg-secondary">85</span>
                        </div>
                        <div class="ms-auto d-flex gap-2">
                            <button type="button" class="btn btn-sm btn-outline-secondary image-optimizer-select-all">
                                {{ 'Select All' | trans }}
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-secondary image-optimizer-deselect-all">
                                {{ 'Deselect All' | trans }}
                            </button>
                        </div>
                    </div>

                    <!-- Image list (scrollable table) -->
                    <div class="image-optimizer-queue" style="max-height: 350px; overflow-y: auto;">
                        <table class="table table-striped table-sm table-hover mb-0">
                            <thead class="sticky-top bg-white">
                                <tr>
                                    <th style="width: 40px;" class="text-center">
                                        <input type="checkbox" class="form-check-input image-optimizer-toggle-all" title="{{ 'Select/Deselect All' | trans }}">
                                    </th>
                                    <th style="width: 60px;">{{ 'Preview' | trans }}</th>
                                    <th>{{ 'Filename' | trans }}</th>
                                    <th style="width: 80px;">{{ 'Type' | trans }}</th>
                                    <th style="width: 100px;">{{ 'Original' | trans }}</th>
                                    <th style="width: 100px;">{{ 'Estimated' | trans }}</th>
                                    <th style="width: 120px;">{{ 'Savings' | trans }}</th>
                                    <th style="width: 120px;">{{ 'Status' | trans }}</th>
                                </tr>
                            </thead>
                            <tbody class="image-optimizer-tbody">
                                <!-- Rows populated by JavaScript -->
                            </tbody>
                        </table>
                    </div>

                    <!-- Summary panel -->
                    <div class="image-optimizer-summary bg-light p-3 rounded mt-3">
                        <div class="row text-center">
                            <div class="col">
                                <strong class="summary-selected fs-5">0</strong>
                                <br>
                                <small class="text-muted">{{ 'Selected' | trans }}</small>
                            </div>
                            <div class="col">
                                <strong class="summary-original fs-5">0 KB</strong>
                                <br>
                                <small class="text-muted">{{ 'Original' | trans }}</small>
                            </div>
                            <div class="col">
                                <strong class="summary-estimated fs-5">-</strong>
                                <br>
                                <small class="text-muted">{{ 'Estimated' | trans }}</small>
                            </div>
                            <div class="col">
                                <strong class="summary-savings fs-5 text-success">-</strong>
                                <br>
                                <small class="text-muted">{{ 'Savings' | trans }}</small>
                            </div>
                        </div>
                    </div>

                    <!-- Confirmation panel (hidden by default) -->
                    <div class="image-optimizer-confirm-panel d-none mt-3">
                        <div class="alert alert-warning mb-3">
                            <strong>{{ 'Warning:' | trans }}</strong>
                            {{ 'Optimizing images may reduce quality. This action cannot be undone.' | trans }}
                        </div>
                        <p class="mb-0">{{ 'Do you want to optimize the selected images?' | trans }}</p>
                    </div>

                    <!-- Progress panel (hidden by default) -->
                    <div class="image-optimizer-progress-panel d-none mt-3">
                        <div class="d-flex align-items-center gap-3 mb-2">
                            <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                            <span class="image-optimizer-progress-text fw-semibold">{{ 'Optimizing...' | trans }}</span>
                        </div>
                        <div class="progress" style="height: 20px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated image-optimizer-progress-bar"
                                 role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
                                <span class="image-optimizer-progress-percent">0%</span>
                            </div>
                        </div>
                        <p class="text-muted small mt-2 mb-0 image-optimizer-progress-detail"></p>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <!-- Normal footer buttons -->
                <div class="image-optimizer-footer-normal">
                    <button type="button" class="btn btn-primary image-optimizer-optimize-btn" disabled>
                        {{ 'Optimize' | trans }}
                    </button>
                    <button type="button" class="close btn btn-outline-secondary" data-dismiss="modal">
                        {{ 'Close' | trans }}
                    </button>
                </div>
                <!-- Confirmation footer buttons (hidden by default) -->
                <div class="image-optimizer-footer-confirm d-none">
                    <button type="button" class="btn btn-warning image-optimizer-confirm-btn">
                        {{ 'Optimize' | trans }}
                    </button>
                    <button type="button" class="btn btn-outline-secondary image-optimizer-cancel-btn">
                        {{ 'Cancel' | trans }}
                    </button>
                </div>
                <!-- Progress footer (hidden by default) -->
                <div class="image-optimizer-footer-progress d-none">
                    <button type="button" class="btn btn-outline-secondary" disabled>
                        {{ 'Processing...' | trans }}
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
